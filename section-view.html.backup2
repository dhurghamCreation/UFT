const SOCIETIES_KEY='uftJoinedSocieties';
function t(lang,key){return (locale[lang]&&locale[lang][key])||locale.en[key]||key}
function getLang(){return document.getElementById('languageSelect').value||localStorage.getItem('uftLanguage')||'en'}
const locale = languagePacks;
const meta={undergrad:{title:'Undergraduate Studies',badge:'UNDERGRADUATE STUDIES',subtitle:'Find a course with detailed key information, modules, application process, fees, and career routes.',hero:'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=1600',brochure:'assets/degrees/bsc-handbook.pdf',payment:'payment.html?course=Undergraduate%20Application&price=0'},postgrad:{title:'Postgraduate Programmes',badge:'POSTGRADUATE PROGRAMMES',subtitle:'Masters and PhD routes with full pathway details, research options, fees, and progression.',hero:'https://images.unsplash.com/photo-1519452635265-7b1fbfd1e4e0?w=1600',brochure:'assets/degrees/degree-specs.pdf',payment:'payment.html?course=Postgraduate%20Application&price=0'},digital:{title:'Digital Learning',badge:'DIGITAL LEARNING COURSES',subtitle:'Expanded digital course list with clickable full details for each course.',hero:'https://images.unsplash.com/photo-1516321165247-4aa89a48be28?w=1600',brochure:'assets/degrees/degree-specs.pdf',payment:'payment.html?course=Digital%20Learning&price=299'},events:{title:'Events Calendar',badge:'EVENTS CALENDAR',subtitle:'Calendar, event cards, images, and people-focused details.',hero:'https://images.unsplash.com/photo-1505373877841-8d25f7d46678?w=1600',brochure:'assets/degrees/degree-specs.pdf',payment:'payment.html?course=Events%20Registration&price=0'},clubs:{title:'Clubs and Societies',badge:'CLUBS AND SOCIETIES',subtitle:'Student communities that are animated, practical, and full of personality.',hero:'https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?w=1600',brochure:'assets/degrees/Student%20Handbook.pdf',payment:'payment.html?course=Clubs%20and%20Societies&price=0'},activities:{title:'Sports and Activities',badge:'SPORTS AND ACTIVITIES',subtitle:'Athletics, wellness, and adventure experiences with clear student pathways.',hero:'https://images.unsplash.com/photo-1461896836934-bd45ba8fcf9b?w=1600',brochure:'assets/degrees/Student%20Handbook.pdf',payment:'payment.html?course=Sports%20and%20Activities&price=0'},research:{title:'Research and Innovation',badge:'RESEARCH AND INNOVATION',subtitle:'Labs, funding, partnerships, and outputs with a stronger visual identity.',hero:'https://images.unsplash.com/photo-1560439514-4e9645039924?w=1600',brochure:'assets/degrees/degree-specs.pdf',payment:'payment.html?course=Research%20and%20Innovation&price=0'},campusmap:{title:'Campus Map',badge:'CAMPUS MAP',subtitle:'Map and media section with clickable location highlights.',hero:'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1600',brochure:'assets/degrees/Student%20Handbook.pdf',payment:'payment.html?course=Campus%20Tour&price=0'},libraries:{title:'Libraries',badge:'LIBRARY EXPERIENCE',subtitle:'Animated media and relevant content specific to library services.',hero:'https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=1600',brochure:'assets/degrees/Student%20Handbook.pdf',payment:'payment.html?course=Library%20Services&price=0'},volunteering:{title:'Volunteering',badge:'VOLUNTEERING',subtitle:'Community projects and media-rich section content.',hero:'https://images.unsplash.com/photo-1469571486292-b53601020f90?w=1600',brochure:'assets/degrees/Student%20Handbook.pdf',payment:'payment.html?course=Volunteering%20Programme&price=0'},catalog:{title:'Course Catalog',badge:'FULL COURSE CATALOG',subtitle:'Consultation, meetings, route fit, and detailed course profiles.',hero:'https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=1600',brochure:'assets/degrees/degree-specs.pdf',payment:'payment.html?course=Catalog%20Consultation&price=0'}};
const ug=[{name:'BSc Computer Science',code:'UFT501',college:'College of Science and Engineering',category:'Engineering',duration:'4 Years',fees:'$25,000 / year',entry:'AAB with Maths',about:'Software systems, AI, and scalable architecture.',study:['Programming foundations','Algorithms and data structures','Software engineering','AI and machine learning'],apply:'Apply through undergraduate route with maths evidence.',funding:'Merit and access scholarships available.',career:['Software Engineer','ML Engineer','Systems Developer']},{name:'MEng Electrical and Electronic Engineering',code:'UFT414',college:'College of Science and Engineering',category:'Engineering',duration:'5 Years',fees:'$26,500 / year',entry:'AAA with Maths and Physics',about:'Power systems, electronics, embedded and communications.',study:['Circuit analysis','Embedded systems','Signal processing','Smart grids'],apply:'Submit transcript and technical statement.',funding:'Industry scholarship options.',career:['Electrical Engineer','Embedded Engineer','Energy Systems Analyst']},{name:'BSc Biological and Chemical Sciences',code:'UFT123',college:'College of Science and Engineering',category:'Science',duration:'4 Years',fees:'$24,800 / year',entry:'AAB with one lab science',about:'Gateway into bioscience, environment, and industrial chemistry routes.',study:['General chemistry','Biology for biosciences','Science maths','Laboratory practice'],apply:'Apply to science route then choose pathway in year one.',funding:'Science bursaries available.',career:['Biochemist','Environmental Scientist','Research Assistant']},{name:'BDS Dentistry',code:'UFT535',college:'College of Medicine, Nursing and Health Sciences',category:'Dentistry',duration:'5 Years',fees:'$31,200 / year',entry:'AAA plus interview',about:'Dental science with supervised clinical progression.',study:['Oral biology','Dental materials','Clinical methods','Public oral health'],apply:'Interview stage after academic review.',funding:'Clinical excellence scholarships.',career:['General Dentist','Public Oral Health Officer']},{name:'MPharm Pharmacy',code:'UFT550',college:'College of Medicine, Nursing and Health Sciences',category:'Pharmacy',duration:'5 Years',fees:'$29,900 / year',entry:'AAA with Chemistry',about:'Pharmacology, medicinal chemistry, and clinical placement routes.',study:['Pharmacology','Medicinal chemistry','Clinical therapeutics','Regulatory practice'],apply:'Chemistry prerequisite and motivation statement required.',funding:'Healthcare scholarships.',career:['Hospital Pharmacist','Community Pharmacist']},{name:'BA Arts and Humanities',code:'UFT101',college:'College of Arts, Social Sciences and Celtic Studies',category:'Arts',duration:'4 Years',fees:'$21,800 / year',entry:'ABB',about:'Flexible arts route with history, media, language, and social thought pathways.',study:['History pathways','Media and communication','Cultural studies','Research methods'],apply:'Choose major and optional minors in first year.',funding:'Arts and travel grants.',career:['Policy Analyst','Journalist','Cultural Programme Officer']},{name:'BCom Accounting and Finance',code:'UFT207',college:'College of Business, Public Policy and Law',category:'Business',duration:'4 Years',fees:'$25,400 / year',entry:'ABB with Maths',about:'Accounting, finance, analytics, and management decision-making.',study:['Financial reporting','Corporate finance','Taxation','Business analytics'],apply:'Apply through undergraduate business listing.',funding:'Business school bursaries.',career:['Accountant','Financial Analyst','Audit Associate']},{name:'BCL Law and Business',code:'UFT250',college:'College of Business, Public Policy and Law',category:'Law',duration:'4 Years',fees:'$24,900 / year',entry:'AAA',about:'Combined law and business route focused on legal and corporate practice.',study:['Contract law','Constitutional law','Business governance','Commercial regulation'],apply:'Apply through undergraduate law route.',funding:'Law access scholarships.',career:['Legal Analyst','Compliance Officer']}] ;
