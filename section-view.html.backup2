<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UFT | Section View</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23ff5100'/%3E%3Cstop offset='100%25' stop-color='%23cc4100'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='64' height='64' rx='14' fill='%23002d5a'/%3E%3Cpath d='M18 15h28v8H35v26h-6V23H18z' fill='url(%23g)'/%3E%3C/svg%3E">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{--primary:#ff5100;--primary-dark:#cc4100;--secondary:#002d5a;--accent:#00f2ff;--text:#1e293b;--muted:#64748b;--dim:#94a3b8;--dark:#0f172a;--white:#fff;--bg:#f8fafc;--border:#e2e8f0;--success:#10b981}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}
.top-bar{background:linear-gradient(90deg,var(--primary),var(--primary-dark));padding:8px 6%;text-align:center;color:#fff;font-size:.74rem;font-weight:800;letter-spacing:2px}
header{background:#fff;border-bottom:4px solid var(--primary);height:66px;padding:0 36px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:50;box-shadow:0 6px 24px rgba(0,0,0,.08)}
.brand{display:flex;align-items:center;gap:10px;text-decoration:none;color:inherit}
.brand-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--primary),var(--primary-dark));display:grid;place-items:center;color:#fff}
.brand-text div:first-child{font-weight:900;color:var(--secondary);font-size:1.15rem}
.brand-text div:first-child span{color:var(--primary)}
.brand-text div:last-child{font-size:.52rem;color:var(--dim);letter-spacing:2px;text-transform:uppercase}
.header-actions{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.lang{display:flex;align-items:center;gap:8px;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:6px 10px}
.lang select{border:none;background:transparent;color:var(--secondary);font-weight:700;outline:none}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:10px 18px;border-radius:10px;border:none;font:inherit;font-size:.85rem;font-weight:700;cursor:pointer;text-decoration:none;transition:.25s}
.btn-primary{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff}
.btn-soft{background:var(--bg);border:1px solid var(--border);color:var(--secondary)}
.btn:hover{transform:translateY(-2px)}
.btn-primary:hover{box-shadow:0 12px 30px rgba(255,81,0,0.35)}
.btn-soft:hover{background:#fff;border-color:var(--primary);color:var(--primary)}
.hero{min-height:48vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;padding:56px 6%}
.hero::before{content:'';position:absolute;inset:0;background:var(--hero) center/cover no-repeat;opacity:.18}
.hero::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,45,90,.88),rgba(15,23,42,.9))}
.hero-content{position:relative;z-index:2;width:min(1120px,96%);text-align:center;color:#fff}
.hero-badge{display:inline-block;padding:7px 18px;border-radius:999px;background:rgba(255,81,0,.2);border:1px solid rgba(255,255,255,.2);color:var(--accent);font-size:.72rem;letter-spacing:2px;font-weight:800;margin-bottom:16px}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,6vw,4rem);margin-bottom:14px;line-height:1.08}
.hero p{max-width:860px;margin:0 auto 26px;color:rgba(255,255,255,.9);line-height:1.8}
.hero-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.hero-actions .btn-soft{background:#fff;color:#0f172a;border-color:#fff}
.section{padding:52px 6%}
.shell{max-width:1220px;margin:0 auto}
.title{font-size:2rem;color:var(--secondary);font-weight:900;margin-bottom:10px}
.sub{color:var(--muted);line-height:1.8;max-width:900px}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin:22px 0}
.stat{background:#fff;border:1px solid var(--border);border-bottom:4px solid var(--primary);border-radius:12px;padding:18px;text-align:center}
.stat strong{display:block;color:var(--secondary);font-size:1.9rem}
.stat span{font-size:.76rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted)}
.card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:0 4px 14px rgba(0,0,0,.03);transition:transform .3s,box-shadow .3s}
.card:hover{transform:translateY(-5px);box-shadow:0 15px 40px rgba(0,0,0,0.08)}
.card h3,.card h4{color:var(--secondary)}
.card p{color:var(--muted);line-height:1.7}
.table-wrap{overflow:auto;border-radius:12px;border:1px solid var(--border);margin-top:12px}
table{width:100%;border-collapse:collapse}
th,td{padding:12px 14px;border-bottom:1px solid var(--border);text-align:left;vertical-align:top}
th{background:var(--secondary);color:#fff;font-size:.75rem;text-transform:uppercase;letter-spacing:1px}
.filters{display:flex;gap:10px;flex-wrap:wrap;margin:16px 0}
.filters input,.filters select{padding:11px 12px;border:1px solid var(--border);border-radius:10px;outline:none;background:#fff}
.filters input{flex:1;min-width:240px}
.detail{display:none;margin-top:16px}
.detail.active{display:block}
.grid{display:grid;gap:18px}
.cols{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.ads{margin-top:22px;background:linear-gradient(135deg,var(--secondary),#001d3a);padding:16px;border-radius:14px;color:#fff}
.ads-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;margin-top:10px}
.ad{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.2);border-radius:10px;padding:12px;cursor:pointer}
.ad strong{display:block}
.ad span{font-size:.82rem;color:#e2e8f0}
.acc{display:grid;gap:10px}
.acc-btn{width:100%;text-align:left;background:#fff;border:1px solid var(--border);padding:14px;border-radius:10px;font:inherit;font-weight:700;color:var(--secondary);display:flex;justify-content:space-between;cursor:pointer}
.acc-panel{display:none;border:1px solid var(--border);border-top:none;background:#fff;border-radius:0 0 10px 10px;padding:14px}
.acc-panel.active,.acc-panel.show{display:block}
.events{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.calendar{background:#fff;border:1px solid var(--border);border-radius:12px;padding:14px}
.cal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cal-grid .n{font-size:.72rem;text-transform:uppercase;color:var(--dim);text-align:center;padding:6px 0}
.cal-grid .d{padding:8px 0;text-align:center;border-radius:8px}
.cal-grid .d.event{background:#fff7ed;color:#9a3412;font-weight:700}
.cal-grid .d.today{background:var(--primary);color:#fff;font-weight:800}
.people{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px}
.person{background:#fff;border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:transform .3s,box-shadow .3s}
.person:hover{transform:translateY(-5px);box-shadow:0 10px 30px rgba(0,0,0,0.06)}
.person img{width:100%;height:160px;object-fit:cover}
.person div{padding:10px}
.person h5{color:var(--secondary);margin-bottom:5px}
.person p{color:var(--muted);font-size:.86rem;line-height:1.6}
.map{border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-top:14px}
.map iframe{width:100%;height:420px;border:0}
.media{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
.media-card{position:relative;border-radius:12px;overflow:hidden;min-height:220px}
.media-card img,.media-card video{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s}
.media-card:hover img,.media-card:hover video{transform:scale(1.07)}
.media-card .overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.1),rgba(0,0,0,.7));display:flex;align-items:flex-end;padding:12px;color:#fff;font-weight:700}
.callout{margin-top:24px;background:linear-gradient(135deg,var(--secondary),#001d3a);border-radius:14px;padding:20px;color:#fff;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
.society-fallback{position:fixed;inset:0;background:rgba(15,23,42,.72);backdrop-filter:blur(10px);display:none;align-items:stretch;justify-content:stretch;z-index:80;padding:0}.society-fallback.show{display:flex}.society-fallback__panel{width:100vw;height:100vh;overflow:auto;background:#fff;border-radius:0;box-shadow:none;position:relative}.society-fallback__close{position:fixed;top:14px;right:14px;width:42px;height:42px;border:none;border-radius:50%;background:#fff;color:var(--secondary);font-size:1.6rem;cursor:pointer;box-shadow:0 8px 24px rgba(0,0,0,.12);transition:.2s;z-index:95}.society-fallback__close:hover{background:#ef4444;color:#fff}
.motion-ready{opacity:0;transform:translateY(16px)}
.motion-in{animation:riseIn .7s cubic-bezier(.16,.84,.3,1) forwards}
@keyframes riseIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
footer{background:var(--dark);color:var(--dim);padding:34px 6% 20px;text-align:center;margin-top:40px}
@media (max-width:980px){header{padding:8px 14px;height:auto;min-height:66px;flex-wrap:wrap}.cols,.events,.media,.grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="top-bar">UFT SECTION VIEW 2026 · DYNAMIC PROGRAMMES</div>
<header>
  <a class="brand" href="index.html"><div class="brand-icon"><i class="fas fa-compass"></i></div><div class="brand-text"><div>UFT <span>Explorer</span></div><div>CS Year 1 - Foundations</div></div></a>
  <div class="header-actions">
    <div class="lang"><i class="fas fa-language" style="color:var(--primary)"></i><select id="languageSelect"><option value="en">English</option><option value="es">Espanol</option><option value="fr">Francais</option><option value="de">Deutsch</option><option value="pt">Portugues</option></select></div>
    <a class="btn btn-soft" href="index.html"><i class="fas fa-home"></i> <span id="backHomeLabel">Home</span></a>
    <a class="btn btn-primary" href="application.html"><i class="fas fa-sign-in-alt"></i> <span id="applyLabel">Log in</span></a>
  </div>
</header>
<main id="sectionRoot"></main>
<div id="societyFallback" class="society-fallback" aria-hidden="true"></div>
<footer>Version <span id="siteVersion">2026.05.24.6</span> · UFT University · All rights reserved</footer>
<script>
const siteVersion='2026.05.24.6';
const sectionSlug=new URLSearchParams(window.location.search).get('section')||'undergrad';
