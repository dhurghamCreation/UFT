udy:['Research design','Publication seminars','Doctoral thesis','Conference outputs'],apply:'Supervisor contact plus proposal.',funding:'Tuition waiver and stipend routes.',career:['Research Scientist','University Academic']}];
const digitalCourses=[{name:'AI for Everyone',price:299,length:'4 weeks',mode:'Online',summary:'Beginner AI route with practical tools and ethical foundations.',modules:['AI basics','Prompt engineering','Ethics','Mini project']},{name:'Data Analytics Bootcamp',price:499,length:'6 weeks',mode:'Online live',summary:'Hands-on analytics with SQL and dashboards.',modules:['SQL analytics','Dashboarding','A/B testing','Case project']},{name:'Cybersecurity Essentials',price:599,length:'8 weeks',mode:'Online lab',summary:'Security operations and incident response training.',modules:['Threat modelling','SOC workflows','Response labs','Security reporting']},{name:'Cloud Engineering Associate',price:650,length:'7 weeks',mode:'Online lab',summary:'Cloud deployment and monitoring for production environments.',modules:['Architecture','Containers','Monitoring','Cost optimisation']},{name:'Product Management for Tech',price:420,length:'5 weeks',mode:'Hybrid online',summary:'Roadmapping, stakeholder management, and metrics.',modules:['Discovery','Roadmaps','Delivery analytics','Communication']},{name:'UX and Interface Design',price:360,length:'5 weeks',mode:'Online',summary:'UX research, prototyping, and accessibility practice.',modules:['Research','Wireframing','Accessibility','Usability testing']}];
const eventsData=[{key:'openDay',date:'2026-05-28',title:'Open Day and Course Expo',time:'10:00',desc:'Programme talks, admissions support desks, and live labs.',img:'https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?w=900'},{key:'innovationForum',date:'2026-06-03',title:'Research and Innovation Forum',time:'13:00',desc:'Faculty and student project showcase with funding partners.',img:'https://images.unsplash.com/photo-1560439514-4e9645039924?w=900'},{key:'leadershipSummit',date:'2026-06-12',title:'Student Leadership Summit',time:'11:00',desc:'Leadership tracks, mentoring sessions, and networking cards.',img:'https://images.unsplash.com/photo-1511578314322-379afb476865?w=900'},{key:'volunteeringWeekend',date:'2026-06-20',title:'Community Volunteering Weekend',time:'09:00',desc:'Outreach projects with local schools and NGOs.',img:'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=900'}];
let calDate=new Date();

// Helper functions
function getSocieties(){try{return JSON.parse(localStorage.getItem(SOCIETIES_KEY)||'[]')}catch{return[]}}
function saveSocieties(items){localStorage.setItem(SOCIETIES_KEY,JSON.stringify(items))}
function addSocietyMembership(club){const list=getSocieties();if(list.some(item=>item.title===club.title))return list;const next=[...list,{title:club.title,hero:club.hero,summary:club.summary,joinedAt:new Date().toISOString(),calendar:club.calendar||[]}];saveSocieties(next);return next}
function openSocietyProfileWindow(encoded){const club=JSON.parse(decodeURIComponent(encoded));const w=window.open('','_blank','width=1120,height=860');if(!w)return;const calHtml=(club.calendar||[]).map(item=>'<div class="calendar-item"><strong>'+item.day+'</strong><span>'+item.event+'</span></div>').join('')||'<div class="calendar-item"><strong>Weekly</strong><span>Open meetings, socials, and member sessions</span></div>';w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>'+club.title+' - Profile</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{margin:0;font-family:Inter,sans-serif;background:linear-gradient(180deg,#fff,#f8fafc);color:#1e293b}.hero{min-height:34vh;background:url(\''+club.hero+'\') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:\'\';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,45,90,.12),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;font-size:clamp(2rem,4vw,3.6rem);margin:0;padding:28px}.shell{padding:24px;max-width:1120px;margin:0 auto}.card{background:#fff;border:1px solid #e2e8f0;border-radius:18px;padding:18px;box-shadow:0 10px 28px rgba(15,23,42,.06)}.grid2{display:grid;grid-template-columns:1.1fr .9fr;gap:14px;margin-top:14px}.gallery{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px}.img{border-radius:18px;overflow:hidden;min-height:240px;position:relative}.img img{width:100%;height:100%;object-fit:cover;display:block}.overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.72));color:#fff;display:flex;align-items:flex-end;padding:14px;font-weight:800}.pill{display:inline-block;padding:7px 12px;border-radius:999px;background:#fff7ed;color:#ff5100;border:1px solid #fed7aa;font-weight:800;font-size:.75rem}.action-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 16px;border-radius:12px;border:none;font:inherit;font-weight:800;cursor:pointer;margin:4px}.btn-primary{background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.btn-soft{background:#fff;border:1px solid #e2e8f0;color:#002d5a}.calendar-item{display:flex;justify-content:space-between;padding:12px 14px;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0;margin-bottom:8px}.calendar-item strong{color:#002d5a}.calendar-item span{color:#64748b;text-align:right}.section-title{color:#002d5a;font-weight:900;margin:0 0 8px}.tiny{font-size:.9rem;color:#64748b;line-height:1.7}@media(max-width:860px){.grid2,.gallery{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>'+club.title+'</h1></div><div class="shell"><div class="card"><span class="pill">Profile window</span><p style="margin-top:12px;line-height:1.8">'+club.summary+'</p><div class="action-row"><button class="btn btn-primary" onclick="document.querySelector(\'.grid2\').scrollIntoView({behavior:\'smooth\'})"><i class="fas fa-user"></i> View Profile</button><button class="btn btn-soft" onclick="window.close()"><i class="fas fa-xmark"></i> Close</button><button class="btn btn-soft" onclick="window.open(\'\',\'_blank\',\'width=1200,height=800\').document.write(window.opener?window.opener.document.title:\'\')"><i class="fas fa-id-card"></i> My Societies</button></div></div><div class="grid2"><div class="card"><h3 class="section-title">Club profile</h3><p class="tiny">'+club.profile+'</p><div style="margin-top:12px"><strong>Focus</strong><p class="tiny">'+club.focus+'</p></div><div style="margin-top:12px"><strong>What members do</strong><p class="tiny">'+club.activities+'</p></div></div><div class="card"><h3 class="section-title">Calendar</h3><div class="calendar" style="display:grid;gap:10px">'+calHtml+'</div></div></div><div class="gallery"><div class="img"><img src="'+club.hero+'" alt="'+club.title+'"><div class="overlay">'+club.detail+'</div></div><div class="img"><img src="https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?w=1200" alt="Members"><div class="overlay">Members, events, and society life</div></div></div></div></body></html>');w.document.close()}
function openSocietyJoinWindow(encoded){const club=JSON.parse(decodeURIComponent(encoded));const w=window.open('','_blank','width=1120,height=860');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Join '+club.title+'</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{margin:0;font-family:Inter,sans-serif;background:linear-gradient(180deg,#fff,#f8fafc);color:#1e293b}.hero{min-height:32vh;background:url(\''+club.hero+'\') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:\'\';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,81,0,.10),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;font-size:clamp(2rem,4vw,3.4rem);margin:0;padding:28px}.shell{padding:24px;max-width:1120px;margin:0 auto}.card{background:#fff;border:1px solid #e2e8f0;border-radius:18px;padding:18px;box-shadow:0 10px 28px rgba(15,23,42,.06)}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 16px;border-radius:12px;border:none;font:inherit;font-weight:800;cursor:pointer;margin-top:10px;text-decoration:none}.btn-primary{background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.btn-soft{background:#fff;border:1px solid #e2e8f0;color:#002d5a}.pill{display:inline-block;padding:7px 12px;border-radius:999px;background:#fef3c7;color:#92400e;border:1px solid #fde68a;font-weight:800;font-size:.75rem}.form{display:grid;gap:12px;margin-top:12px}.field{display:grid;gap:6px}.field input{padding:12px 14px;border:1px solid #e2e8f0;border-radius:10px;font:inherit}.note{color:#64748b;line-height:1.7}.calendar-item{display:flex;justify-content:space-between;padding:12px 14px;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0;margin-bottom:8px}.calendar-item strong{color:#002d5a}.calendar-item span{color:#64748b;text-align:right}.feature-list{display:grid;gap:10px}.feature{padding:12px 14px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0}@media(max-width:860px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>Join '+club.title+'</h1></div><div class="shell"><div class="card"><span class="pill">Join window</span><p class="note" style="margin-top:10px">Complete your membership request here. This window is separate from the profile view so the join flow stays clear.</p><div class="form"><div class="field"><label>Email</label><input id="societyEmail" type="email" placeholder="student@uft.edu"></div><div class="field"><label>Motivation</label><input id="societyReason" type="text" placeholder="Why do you want to join?"></div><button class="btn btn-primary" onclick="window.opener.addSocietyMembership({title:\''+club.title+'\',hero:\''+club.hero+'\',summary:\''+club.summary+'\',calendar:'+JSON.stringify(club.calendar||[])+'});this.textContent=\'Joined successfully\';this.disabled=true;window.setTimeout(()=>window.opener.openMySocietiesProfile(),300)"><i class="fas fa-plus"></i> Join society</button><button class="btn btn-soft" onclick="window.close()"><i class="fas fa-xmark"></i> Close</button></div></div><div class="grid2"><div class="card"><h3 style="color:#002d5a;margin-bottom:8px">What joining gives you</h3><div class="feature-list"><div class="feature">Access to meetings, sessions, and events</div><div class="feature">Profile visibility inside My Societies</div><div class="feature">Calendar reminders and activity tracking</div></div></div><div class="card"><h3 style="color:#002d5a;margin-bottom:8px">Upcoming calendar</h3><div class="calendar-item"><strong>Weekly</strong><span>Open member drop-in</span></div><div class="calendar-item"><strong>Next event</strong><span>'+((club.calendar&&club.calendar[0]&&club.calendar[0].event)||'Intro session')+'</span></div><div class="calendar-item"><strong>Join status</strong><span>Ready to submit</span></div></div></div></div></body></html>');w.document.close()}
function openCourseDetails(encoded){openCourseInWindow(JSON.parse(decodeURIComponent(encoded)))}
function openConsultationWindow(){const w=window.open('','_blank','width=980,height=760');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Course Consultation - UFT</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:42px 24px;text-align:center}.hero h1{margin:0;font-size:2.2rem}.shell{max-width:860px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px;box-shadow:0 10px 24px rgba(15,23,42,.05)}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.slot{padding:12px 14px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin-top:10px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.note{color:#64748b;line-height:1.7}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>Course Consultation</h1><p style="margin-top:10px;opacity:.9">Book a route-fitting session before you apply</p></div><div class="shell"><div class="card"><h2 style="color:#002d5a">What happens in consultation?</h2><p class="note">We compare your interests, entry grades, fees, and study goals, then recommend the route that fits you best. This is a separate advising flow, not the application form.</p></div><div class="grid2"><div class="card"><h3 style="color:#002d5a">Available slots</h3><div class="slot">Mon 10:00</div><div class="slot" style="margin-top:8px">Tue 14:30</div><div class="slot" style="margin-top:8px">Thu 11:00</div></div><div class="card"><h3 style="color:#002d5a">Bring with you</h3><div class="slot">Preferred course area</div><div class="slot" style="margin-top:8px">Academic transcript</div><div class="slot" style="margin-top:8px">Questions about fees and funding</div></div></div><div class="card"><h3 style="color:#002d5a">Book your consultation</h3><p class="note">Use this button to open the application page only after your advisory slot is confirmed.</p><a class="btn-p" href="application.html"><i class="fas fa-calendar-check"></i> Confirm consultation</a></div></div></body></html>');w.document.close()}
function openVolunteerWindow(data){const w=window.open('','_blank','width=980,height=760');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>'+data.title+' - Volunteering</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{min-height:280px;background:url(\''+data.img+'\') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:\'\';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,45,90,.12),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;padding:24px;margin:0;font-size:2.2rem}.shell{max-width:860px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin-top:10px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.feature{padding:12px 14px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0;margin-top:8px}.note{color:#64748b;line-height:1.7}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>'+data.title+'</h1></div><div class="shell"><div class="card"><h2 style="color:#002d5a">'+data.heading+'</h2><p class="note">'+data.text+'</p></div><div class="grid2"><div class="card"><h3 style="color:#002d5a">Why it matters</h3><div class="feature">'+data.one+'</div><div class="feature">'+data.two+'</div><div class="feature">'+data.three+'</div></div><div class="card"><h3 style="color:#002d5a">Next steps</h3><p class="note">Join a project, meet the team, and sign up for the next volunteer day.</p><a class="btn-p" href="application.html"><i class="fas fa-heart"></i> Get involved</a></div></div></div></body></html>');w.document.close()}
function downloadPDF(type){const filePath={about:'assets/degrees/UFT_University_Prospectus.pdf',undergrad:'assets/degrees/bsc-handbook.pdf',postgrad:'assets/degrees/degree-specs.pdf',digital:'assets/degrees/degree-specs.pdf',default:'assets/degrees/degree-specs.pdf'}[type]||'assets/degrees/degree-specs.pdf';const a=document.createElement('a');a.href=filePath;a.download=filePath.split('/').pop();document.body.appendChild(a);a.click();a.remove()}
function openCourseInWindow(course){const w=window.open('','_blank','width=1100,height=800');if(!w)return;w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>${course.name} - UFT</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:40px;text-align:center}.hero h1{margin:0;font-size:2.2rem}.hero .code{color:#ff5100;font-weight:800;margin-top:6px}.shell{max-width:960px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.mg{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px}.mi{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px;text-align:center}.mi strong{display:block;color:#002d5a}.mi span{font-size:.78rem;color:#64748b;text-transform:uppercase;letter-spacing:1px}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff;margin-top:10px}h2{color:#002d5a}ul{line-height:1.9;color:#475569}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>${course.name}</h1><div class="code">${course.code||''}</div></div><div class="shell"><div class="card"><div class="mg"><div class="mi"><strong>${course.duration||'4 Years'}</strong><span>Duration</span></div><div class="mi"><strong>${course.fees||'$25K/yr'}</strong><span>Fees</span></div><div class="mi"><strong>${course.entry||'AAB'}</strong><span>Entry Requirements</span></div><div class="mi"><strong>${course.college||course.school||'UFT'}</strong><span>College</span></div></div><p style="margin-top:14px;line-height:1.8">${course.about||''}</p></div><div class="grid2"><div class="card"><h2>What You Will Study</h2><ul>${(course.study||['Core modules']).map(x=>'<li>'+x+'</li>').join('')}</ul></div><div class="card"><h2>Your Future Career</h2><ul>${(course.career||['Graduate roles']).map(x=>'<li>'+x+'</li>').join('')}</ul></div></div><div class="card"><h2>How to Apply</h2><p>${course.apply||'Apply through UFT online portal.'}</p><p><strong>Funding:</strong> ${course.funding||'Merit and access scholarships available.'}</p><a class="btn-p" href="application.html"><i class="fas fa-file-signature"></i> Apply Now</a></div></div></body></html>`);w.document.close()}
function getMeta(s){return meta[s]||{title:s.replace(/[-_]/g,' ').replace(/\b\w/g,c=>c.toUpperCase()),badge:'SECTION PAGE',subtitle:'Dedicated standalone page with rich content.',hero:'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=1600',brochure:'assets/degrees/degree-specs.pdf',payment:`payment.html?course=${encodeURIComponent(s)}&price=0`}}

// Section renderers
function renderHero(m){return `<section class="hero" style="--hero:url('${m.hero}')"><div class="hero-content"><div class="hero-badge">${m.badge}</div><h1>${m.title}</h1><p>${m.subtitle}</p><div class="hero-actions"><a class="btn btn-primary" href="application.html"><i class="fas fa-file-signature"></i> Apply now</a><a class="btn btn-soft" href="${m.brochure}" onclick="event.preventDefault();downloadPDF('${sectionSlug}')" target="_blank" rel="noopener"><i class="fas fa-file-pdf"></i> Brochure PDF</a><a class="btn btn-soft" href="${m.payment}"><i class="fas fa-credit-card"></i> Payment portal</a></div></div></section>`}
function sectionCourses(type,lang){const d=type==='undergrad'?ug:pg;const groups=[...new Set(d.map(x=>x.category||x.stream))];const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">${type==='undergrad'?'Undergraduate':'Postgraduate'} taught courses</h2><p class="sub">Find your course using filters, then click to open full details in a new window.</p><div class="filters"><input id="courseSearch" placeholder="Start typing to filter the course list"><select id="courseCat"><option value="all">All categories</option>${groups.map(g=>`<option value="${g}">${g}</option>`).join('')}</select></div><div class="table-wrap"><table><thead><tr><th>Course Name</th><th>Code</th><th>College / School</th></tr></thead><tbody id="courseTable"></tbody></table></div><div class="card detail" id="courseDetail"></div></div></section>`}
function sectionDigital(){return `<section class="section"><div class="shell"><h2 class="title">Digital learning catalogue</h2><p class="sub">Each course is clickable and reveals full details with price, length, modules, and payment action.</p><div class="acc">${digitalCourses.map((c,i)=>`<div><button class="acc-btn" onclick="toggleCourse(${i})"><span>${c.name} · $${c.price} · ${c.length}</span><i class="fas fa-chevron-down"></i></button><div class="acc-panel" id="acc-${i}"><p><strong>Mode:</strong> ${c.mode}</p><p style="margin-top:8px">${c.summary}</p><div class="table-wrap"><table><thead><tr><th>Field</th><th>Details</th></tr></thead><tbody><tr><td>Price</td><td>$${c.price}</td></tr><tr><td>Length</td><td>${c.length}</td></tr><tr><td>Modules</td><td>${c.modules.join(', ')}</td></tr></tbody></table></div><div style="margin-top:10px;display:flex;gap:10px"><a class="btn btn-primary btn-sm" href="payment.html?course=${encodeURIComponent(c.name)}&price=${c.price}"><i class="fas fa-credit-card"></i> Payment</a><button class="btn btn-soft btn-sm" onclick="openCourseInWindow({name:'${c.name}',code:'',college:'Digital Learning',duration:'${c.length}',fees:'$${c.price}',entry:'None',about:'${c.summary}',study:${JSON.stringify(c.modules)},career:['Digital Professional'],apply:'Enroll online',funding:'Self-funded'})">View Details <i class="fas fa-external-link-alt"></i></button></div></div></div>`).join('')}</div></div></section>`}
function sectionEvents(lang){return `<section class="section"><div class="shell"><h2 class="title">Events Calendar</h2><p class="sub">Calendar with event days, cards, and richer event descriptions.</p><div class="events"><div class="calendar"><div class="cal-head"><button class="btn btn-soft" onclick="moveMonth(-1)"><i class="fas fa-chevron-left"></i></button><strong id="monthLabel"></strong><button class="btn btn-soft" onclick="moveMonth(1)"><i class="fas fa-chevron-right"></i></button></div><div class="cal-grid" id="calGrid"></div></div><div class="people">${eventsData.map(e=>`<div class="person" style="cursor:pointer" onclick="goEvent('${e.key}')"><img src="${e.img}" alt="${e.title}"><div><h5>${e.title}</h5><p><strong>${e.date}</strong> at ${e.time}<br>${e.desc}</p></div></div>`).join('')}</div></div></div></section>`}
function sectionClubs(lang){const l=lang||'en';const clubs=[{title:'Robotics Club',hero:'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1200',summary:'Competition robotics, autonomous systems, and maker culture.',detail:'Build robots, test sensors, and develop systems for live competitions.',profile:'Robotics Club blends hardware prototyping, code, and team competition.',focus:'Mechanical design, embedded code, and autonomous systems.',activities:'Weekly build nights, competition drills, and maker sessions.',calendar:[{day:'Mon',event:'Build Night'},{day:'Wed',event:'Sensor Lab'},{day:'Fri',event:'Robot Scrimmage'}]},{title:'Athletics Society',hero:'https://images.unsplash.com/photo-1461896836934-bd45ba8fcf9b?w=1200',summary:'Running, track events, performance coaching, and strength support.',detail:'Structured sprint sessions, endurance runs, and performance analysis.',profile:'Athletics Society is the campus hub for runners, sprinters, and strength athletes.',focus:'Track performance, recovery, and coaching support.',activities:'Track intervals, tempo runs, gym sessions, and race prep.',calendar:[{day:'Tue',event:'Track Warm-up'},{day:'Thu',event:'Endurance Run'},{day:'Sat',event:'Performance Session'}]},{title:'Creative Tech Collective',hero:'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1200',summary:'Design, film, motion graphics, and digital storytelling.',detail:'Collaborate on media projects, events branding, and digital campaigns.',profile:'Creative Tech Collective mixes design, film, and motion graphics for student storytelling.',focus:'Brand design, editing, motion, and digital media.',activities:'Content shoots, motion labs, and portfolio reviews.',calendar:[{day:'Mon',event:'Design Studio'},{day:'Thu',event:'Film Night'},{day:'Sun',event:'Portfolio Clinic'}]},{title:'Debate and Leadership Union',hero:'https://images.unsplash.com/photo-1511578314322-379afb476865?w=1200',summary:'Public speaking, policy debate, and leadership challenge nights.',detail:'Practice formal debate, presentations, and committee leadership.',profile:'Debate and Leadership Union trains speakers, chairpersons, and student leaders.',focus:'Public speaking, policy debate, and leadership.',activities:'Debate nights, speech coaching, and leadership challenges.',calendar:[{day:'Wed',event:'Moot Debate'},{day:'Fri',event:'Speech Lab'},{day:'Sat',event:'Leadership Night'}]}];return `<section class="section"><div class="shell"><h2 class="title">Clubs and Societies</h2><p class="sub">Student communities that are animated, practical, and full of personality.</p><div class="card" style="margin:18px 0 22px"><h3 style="color:var(--secondary);margin-bottom:8px">How to join</h3><div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:12px"><div class="card" style="box-shadow:none"><strong>1. Explore</strong><p>Open a society spotlight to see what members do.</p></div><div class="card" style="box-shadow:none"><strong>2. Verify</strong><p>Two-step verification confirms your membership request.</p></div><div class="card" style="box-shadow:none"><strong>3. Track</strong><p>Joined societies appear in your profile dashboard window.</p></div></div><div style="margin-top:12px"><button class="btn btn-primary" type="button" onclick="openMySocietiesProfile()"><i class="fas fa-id-card"></i> My Societies</button></div></div><div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(250px,1fr));margin-top:14px">${clubs.map(c=>`<div class="card" style="padding:0;overflow:hidden"><img src="${c.hero}" alt="${c.title}" style="width:100%;height:220px;object-fit:cover;display:block"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">${c.title}</h4><p style="margin:0;color:var(--muted)">${c.summary}</p></div><div style="padding:0 18px 18px;display:flex;gap:10px"><button class="btn btn-soft btn-sm" style="flex:1;justify-content:center" onclick="openClubPopup('${encodeURIComponent(JSON.stringify(c))}',false)">View Profile</button><button class="btn btn-primary btn-sm" style="flex:1;justify-content:center" onclick="openClubPopup('${encodeURIComponent(JSON.stringify(c))}',true)">Join</button></div></div>`).join('')}</div></div></section>`}
function sectionActivities(lang){const l=lang||'en';const rows=[{title:'Varsity Athletics',img:'https://images.unsplash.com/photo-1461896836934-bd45ba8fcf9b?w=1200',desc:'15 competitive teams across basketball, swimming, football, and track.'},{title:'Titan Gym and Recovery',img:'https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=1200',desc:'Strength training, recovery space, and performance support.'},{title:'Outdoor Adventure',img:'https://images.unsplash.com/photo-1518602164578-cd0074062767?w=1200',desc:'Kayaking, hiking, weekend trips, and challenge-based activities.'},{title:'Wellbeing in Motion',img:'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1200',desc:'Yoga, wellness walks, and stress-management sessions for students.'}];const plan=[['Monday','06:30','Track mechanics + sprint starts'],['Tuesday','17:00','Strength circuit + power work'],['Wednesday','18:30','Endurance interval blocks'],['Thursday','16:00','Mobility + recovery protocols'],['Friday','15:30','Game strategy and set pieces']];return `<section class="section"><div class="shell"><h2 class="title">Sports and Activities</h2><p class="sub">Athletics, wellness, and adventure experiences with clear student pathways.</p><div class="card" style="margin-bottom:14px"><h3>Sports Performance Hub</h3><p>Elite training, match analytics, recovery science, and student wellness in one connected experience.</p><div class="stats"><div class="stat"><strong data-count="42">0</strong><span>Competitive teams</span></div><div class="stat"><strong data-count="8">0</strong><span>Performance labs</span></div><div class="stat"><strong data-count="96">0</strong><span>Student participation</span></div><div class="stat"><strong data-count="24">0</strong><span>Gym access</span></div></div></div><div class="card" style="margin-bottom:14px;overflow:hidden;padding:0"><video controls playsinline muted autoplay loop poster="https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=1200" style="width:100%;height:520px;object-fit:cover;display:block"><source src="https://assets.mixkit.co/videos/preview/mixkit-people-jogging-on-a-running-track-35973-large.mp4" type="video/mp4">Your browser does not support the video tag.</video><div style="padding:16px 18px;background:#fff"><h4 style="margin:0 0 6px;color:var(--secondary)">Featured training reel</h4><p style="margin:0;color:var(--muted)">Watch our athletes in action.</p></div></div><div class="gallery" style="grid-template-columns:1fr .9fr"><div class="img"><img src="${rows[0].img}" alt="${rows[0].title}"><div class="overlay">${rows[0].desc}</div></div><div class="img"><img src="${rows[2].img}" alt="${rows[2].title}"><div class="overlay">${rows[2].desc}</div></div></div><div class="table-wrap" style="margin-top:14px"><table><thead><tr><th>Day</th><th>Time</th><th>Session</th></tr></thead><tbody>${plan.map(p=>`<tr><td>${p[0]}</td><td>${p[1]}</td><td>${p[2]}</td></tr>`).join('')}</tbody></table></div><div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:14px">${rows.map(c=>`<details class="card"><summary style="cursor:pointer;font-weight:800;color:var(--secondary)">${c.title}</summary><p style="margin-top:10px">${c.desc}</p></details>`).join('')}</div></div></section>`}
function sectionResearch(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">Research and Innovation</h2><p class="sub">Labs, funding, partnerships, and outputs with a stronger visual identity.</p><div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:14px"><div class="card" style="cursor:pointer;overflow:hidden;padding:0" onclick="openResearchWindow({title:'AI Ethics Lab',img:'https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=1200',copy:'Responsible AI, fairness, model auditing, and policy design.',researchers:'34',projects:'18',partners:'12',publications:'46'})"><img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">AI Ethics Lab</h4><p style="margin:0">Responsible AI, fairness, model auditing, and policy design.</p></div></div><div class="card" style="cursor:pointer;overflow:hidden;padding:0" onclick="openResearchWindow({title:'Quantum Systems Lab',img:'https://images.unsplash.com/photo-1507413245164-6160d8298b31?w=1200',copy:'Computing, materials, and simulation for the next generation of hardware.',researchers:'27',projects:'14',partners:'9',publications:'39'})"><img src="https://images.unsplash.com/photo-1507413245164-6160d8298b31?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">Quantum Systems Lab</h4><p style="margin:0">Computing, materials, and simulation for the next generation of hardware.</p></div></div><div class="card" style="cursor:pointer;overflow:hidden;padding:0" onclick="openResearchWindow({title:'Cyber Range',img:'https://images.unsplash.com/photo-1516321497487-e288fb19713f?w=1200',copy:'Hands-on security operations, incident response, and digital forensics.',researchers:'31',projects:'21',partners:'16',publications:'52'})"><img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">Cyber Range</h4><p style="margin:0">Hands-on security operations, incident response, and digital forensics.</p></div></div><div class="card" style="cursor:pointer;overflow:hidden;padding:0" onclick="openResearchWindow({title:'BioInnovation Centre',img:'https://images.unsplash.com/photo-1576086213369-97a306d36557?w=1200',copy:'Applied biomedical, chemistry, and translational science projects.',researchers:'24',projects:'11',partners:'8',publications:'33'})"><img src="https://images.unsplash.com/photo-1576086213369-97a306d36557?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">BioInnovation Centre</h4><p style="margin:0">Applied biomedical, chemistry, and translational science projects.</p></div></div></div></div></section>`}
function sectionLibraries(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">UFT Libraries</h2><p class="sub">Digital collections, special archives, study spaces, and research support.</p><div class="accordion"><div><button class="acc-btn" onclick="toggleAccordion(this)">Automatic Renewals <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>All standard loan and 3-day loan items will automatically renew except in cases where another user has requested the item or you have another overdue item. Automatic renewal takes place two days before the due date.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Borrowing Books <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Use the Self Issue machines on all floors with your ID card. If a book is checked out, you can place a hold on it. Maximum books and loan periods vary by borrower category.</p><br><ul><li>Undergraduate: 6 books, 7 days, 9 renewals</li><li>Postgraduate Research: 20 books, 84 days, 3 renewals</li><li>Postgraduate Taught: 10 books, 84 days, 3 renewals</li><li>Staff: 20 books, 84 days, 5 renewals</li></ul></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Recalls <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>If another user requests your book, you will be notified to return it within 3 days or fines will be added to your account.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Lost Books & Fines <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Lost books are charged at replacement cost plus a processing fee. Fines accrue on overdue recalled items.</p></div></div></div></div></section>`}
function sectionVolunteering(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">Volunteering and Community Engagement</h2><p class="sub">Service, outreach, and impact-led community projects.</p><div class="media"><div class="media-card"><img src="https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=1200"><div class="overlay">Community Outreach</div></div><div class="media-card"><img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1200"><div class="overlay">Global Service</div></div><div class="media-card"><video autoplay muted loop playsinline src="https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4"></video><div class="overlay">Animated media block</div></div><div class="media-card"><img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1200"><div class="overlay">Practical pathway content</div></div></div></div></section>`}
function sectionMap(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">Campus Map and highlights</h2><p class="sub">Google map restored with relevant clickable campus content.</p><div class="map"><iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3168.639691016052!2d-122.084!3d37.422!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x808fba02425dad8f%3A0x6c296c!2sGoogleplex!5e0!3m2!1sen!2sus!4v1" loading="lazy" allowfullscreen></iframe></div></div></section>`}
function sectionInternational(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">About UFT Global</h2><p class="sub">University of Fire Tech (UFT) has been named among the top 500 universities globally.</p><div class="grid" style="grid-template-columns:1.2fr .8fr;margin-top:18px"><div class="card"><p>UFT is in the top 2% of universities worldwide. Located in Innovation Valley, California, our campus features state-of-the-art teaching and research facilities. We offer 70+ undergraduate and 100+ postgraduate programmes.</p><div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap"><button class="btn btn-primary" onclick="downloadPDF('about')"><i class="fas fa-download"></i> Download Brochure</button><a class="btn btn-soft" href="application.html">Apply Now</a></div></div><div class="card" style="overflow:hidden;padding:0"><img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1200" style="width:100%;height:320px;object-fit:cover"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">Award-winning campus</h4><p style="margin:0;color:var(--muted)">Voted #1 for student experience</p></div></div></div><div class="stats" style="margin-top:18px"><div class="stat"><strong>70+</strong><span>Undergraduate programmes</span></div><div class="stat"><strong>100+</strong><span>Postgraduate programmes</span></div><div class="stat"><strong>#1</strong><span>Student Innovation</span></div><div class="stat"><strong>Top 2%</strong><span>Universities globally</span></div></div><div class="grid" style="grid-template-columns:1.1fr .9fr;gap:18px;margin-top:18px"><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="openIncomingWindow()"><img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1200" style="width:100%;height:240px;object-fit:cover"><div style="padding:18px"><h3 style="color:var(--secondary);margin:0 0 8px">Incoming Students</h3><p>Are you studying outside the US and looking to come to UFT?</p><button class="btn btn-primary btn-sm" onclick="event.stopPropagation();openIncomingWindow()">Learn More</button></div></div><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="openOutgoingWindow()"><img src="https://images.unsplash.com/photo-1522071823991-b99c223a709e?w=1200" style="width:100%;height:240px;object-fit:cover"><div style="padding:18px"><h3 style="color:var(--secondary);margin:0 0 8px">Outgoing Students</h3><p>Departing on Erasmus or Study Abroad? We have all the info you need.</p><button class="btn btn-primary btn-sm" onclick="event.stopPropagation();openOutgoingWindow()">Learn More</button></div></div></div><div class="callout"><div><h3>UFT Global Office</h3><p>E0-020, University of Fire Tech, Innovation Valley, CA | Get in Touch</p></div><div style="display:flex;gap:10px;flex-wrap:wrap"><button class="btn btn-primary" onclick="openGlobalOfficeWindow()"><i class="fas fa-envelope"></i> global@uft.edu</button><button class="btn btn-soft" onclick="downloadPDF('about')" style="background:#fff;color:#0f172a;border-color:#fff"><i class="fas fa-download"></i> Brochure</button></div></div></div></section>`}
function sectionHelp(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">Help & Support</h2><p class="sub">Contact our support teams for assistance.</p><div class="card" style="margin-bottom:14px"><div class="grid" style="grid-template-columns:1.1fr .9fr;gap:18px"><div><h3 style="color:var(--secondary)">Have a question?</h3><p>Check our <a href="#faqSection" style="color:var(--primary);cursor:pointer">Ask UFT</a> page for FAQs on IT, semester dates, and joining clubs.</p></div><div><h3 style="color:var(--secondary)">Visit us in person</h3><p>Student Central, Innovation Hub building, Ground Floor.</p></div></div></div><div class="card" style="margin-bottom:14px"><h3>Office Hours</h3><table><thead><tr><th>Day</th><th>Morning</th><th>Afternoon</th></tr></thead><tbody><tr><td>Mon-Thu</td><td>9:00-13:00</td><td>14:00-17:00</td></tr><tr><td>Friday</td><td>9:00-13:00</td><td>14:00-17:00</td></tr></tbody></table></div><div class="grid" style="grid-template-columns:1fr 1fr;gap:14px"><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="window.open('mailto:studentservices@uft.edu')"><div style="background:linear-gradient(135deg,var(--secondary),#001d3a);padding:30px;text-align:center;color:#fff"><h4 style="color:#fff">Current Students</h4><p>studentservices@uft.edu</p></div></div><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="window.open('mailto:admissions@uft.edu')"><div style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));padding:30px;text-align:center;color:#fff"><h4 style="color:#fff">Prospective Students</h4><p>admissions@uft.edu</p></div></div></div></div></section>`}
function sectionFAQ(lang){const l=lang||'en';return `<section class="section" id="faqSection"><div class="shell"><h2 class="title">Frequently Asked Questions</h2><p class="sub">Common questions about studying at UFT.</p><div class="accordion"><div><button class="acc-btn" onclick="toggleAccordion(this)">What are the tuition fees? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Undergraduate: $22,000-$25,400/yr. Postgraduate: $30,500-$45,000 total. PhD: fully funded with stipend. 80% of students receive financial aid.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">What accommodation options are available? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Guaranteed on-campus for first year. Options: Fire Hall, Tech Apartments, International House, Graduate Village. All include high-speed internet and 24/7 security.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">How do I apply? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Apply through UFT online portal. Deadlines: Early Decision Nov 15, Regular Jan 15, International Feb 1.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Can I study abroad? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Yes! UFT has 200+ partner universities in 40+ countries. Erasmus+ and exchange programmes available.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Contact UFT <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Email: studentservices@uft.edu | Phone: +1 (800) 438-3863 | Innovation Hub, Ground Floor</p></div></div></div></div></section>`}
function sectionCatalog(lang){const l=lang||'en';const all=[...ug.map(c=>({...c,group:'Undergraduate',org:c.college})),...pg.map(c=>({...c,group:'Postgraduate',org:c.school}))];return `<section class="section"><div class="shell"><h2 class="title">Course catalog and guidance</h2><p class="sub">Includes consultation, meetings, route fit guidance, and full profile information.</p><div class="grid" style="grid-template-columns:1fr 1fr"><div class="card"><h3>Consultation and meeting</h3><p>Book advising sessions to compare routes and entry requirements.</p><a class="btn btn-primary" href="application.html"><i class="fas fa-calendar-check"></i> Book consultation</a></div><div class="card"><h3>Which course is right for you?</h3><p>Filter by school, course code, and study goals, then open full details.</p></div></div><div class="filters"><input id="catalogSearch" placeholder="Search by course name, code, or school"></div><div id="catalogList" class="grid"></div><div id="catalogDetail" class="card detail"></div></div></section>`}
function sectionGeneric(m){return `<section class="section"><div class="shell"><h2 class="title">${m.title}</h2><p class="sub">${m.subtitle}</p></div></section>`}

// Club popup functions
function openClubPopup(encoded,focusJoin){const club=JSON.parse(decodeURIComponent(encoded));const lang=getLang();const w=window.open('','_blank','width=1120,height=860');if(!w)return;const calHtml=(club.calendar||[]).map(i=>'<div class="calendar-item"><strong>'+i.day+'</strong><span>'+i.event+'</span></div>').join('')||'';w.document.write('<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>'+club.title+'</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{margin:0;font-family:Inter,sans-serif;background:linear-gradient(180deg,#fff,#f8fafc);color:#1e293b}.hero{min-height:34vh;background:url(\''+club.hero+'\') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:\'\';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,45,90,.12),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;font-size:clamp(2rem,4vw,3.6rem);margin:0;padding:28px}.shell{padding:24px;max-width:1120px;margin:0 auto}.card{background:#fff;border:1px solid #e2e8f0;border-radius:18px;padding:18px;box-shadow:0 10px 28px rgba(15,23,42,.06)}.grid2{display:grid;grid-template-columns:1.1fr .9fr;gap:14px;margin-top:14px}.gallery{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px}.img{border-radius:18px;overflow:hidden;min-height:240px;position:relative}.img img{width:100%;height:100%;object-fit:cover;display:block}.overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.72));color:#fff;display:flex;align-items:flex-end;padding:14px;font-weight:800}.pill{display:inline-block;padding:7px 12px;border-radius:999px;background:#fff7ed;color:#ff5100;border:1px solid #fed7aa;font-weight:800;font-size:.75rem}.action-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 16px;border-radius:12px;border:none;font:inherit;font-weight:800;cursor:pointer;margin:4px}.btn-primary{background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.btn-soft{background:#fff;border:1px solid #e2e8f0;color:#002d5a}.calendar-item{display:flex;justify-content:space-between;padding:12px 14px;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0;margin-bottom:8px}.calendar-item strong{color:#002d5a}.calendar-item span{color:#64748b;text-align:right}.section-title{color:#002d5a;font-weight:900;margin:0 0 8px}.tiny{font-size:.9rem;color:#64748b;line-height:1.7}@media(max-width:860px){.grid2,.gallery,.join-fields{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>'+club.title+'</h1></div><div class="shell"><div class="card"><span class="pill">'+club.summary+'</span><p style="margin-top:12px;line-height:1.8">'+club.detail+'</p><div class="action-row"><button class="btn btn-primary" onclick="document.querySelector(\'.grid2\').scrollIntoView({behavior:\'smooth\'})"><i class="fas fa-user"></i> View Profile</button><button class="btn btn-soft" onclick="addSocietyMembership({title:\''+club.title+'\',hero:\''+club.hero+'\',summary:\''+club.summary+'\',calendar:'+JSON.stringify(club.calendar||[])+'});this.textContent=\'Joined! \\u2713\';this.disabled=true"><i class="fas fa-plus"></i> Join</button><button class="btn btn-soft" onclick="window.open(\'\',\'_blank\',\'width=1200,height=800\').document.write(window.opener?window.opener.document.title:\'\')"><i class="fas fa-id-card"></i> My Societies</button></div></div><div class="grid2"><div class="card"><h3 class="section-title">Club profile</h3><p class="tiny">'+club.profile+'</p><div style="margin-top:12px"><strong>Focus</strong><p class="tiny">'+club.focus+'</p></div><div style="margin-top:12px"><strong>What members do</strong><p class="tiny">'+club.activities+'</p></div></div><div class="card"><h3 class="section-title">Calendar</h3><div class="calendar" style="display:grid;gap:10px">'+calHtml+'</div></div></div></div></body></html>');w.document.close()}
function openMySocietiesProfile(){const s=getSocieties();const w=window.open('','_blank','width=1200,height=800');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>My Societies - UFT YourSpace</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Inter,sans-serif;background:#f4f7fb;color:#1e293b;display:flex;min-height:100vh}.sidebar{width:270px;background:#0f172a;color:#cbd5e1;padding:24px;display:flex;flex-direction:column;flex-shrink:0}.sidebar .logo{color:#fff;font-weight:900;font-size:1.2rem;margin-bottom:24px}.sidebar .logo span{color:#ff5100}.sidebar .user{display:flex;align-items:center;gap:10px;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid #1e293b}.sidebar .user .avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#ff5100,#cc4100);display:grid;place-items:center;color:#fff;font-weight:900}.sidebar nav{display:grid;gap:4px}.sidebar nav a{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;color:#94a3b8;text-decoration:none;font-size:.9rem;transition:.2s}.sidebar nav a:hover,.sidebar nav a.active{background:#1e293b;color:#fff;cursor:pointer}.sidebar nav a i{width:20px}.main{flex:1;padding:28px;overflow-y:auto}.header-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px}.header-bar h1{font-size:1.5rem;color:#0f172a}.header-bar .badge{background:#ff5100;color:#fff;padding:4px 12px;border-radius:999px;font-size:.8rem;font-weight:700}.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:24px}.stat-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;text-align:center}.stat-card strong{display:block;font-size:2rem;color:#002d5a}.stat-card span{font-size:.8rem;text-transform:uppercase;color:#64748b;letter-spacing:1px}.soc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:14px}.soc-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;transition:.2s}.soc-card img{width:100%;height:150px;object-fit:cover}.soc-card .body{padding:16px}.soc-card .body h4{color:#002d5a;margin-bottom:4px}.soc-card .body p{color:#64748b;font-size:.88rem}.soc-card .body .date{color:#94a3b8;font-size:.8rem;margin-top:8px}.empty{text-align:center;padding:60px 20px;color:#94a3b8}.empty i{font-size:3rem;margin-bottom:16px;color:#e2e8f0}@media(max-width:800px){body{flex-direction:column}.sidebar{width:100%}}</style></head><body><div class="sidebar"><div class="logo">UFT <span>YourSpace</span></div><div class="user"><div class="avatar">S</div><div><strong style="color:#fff">Student</strong><br><small style="color:#64748b">My profile</small></div></div><nav><a class="active" onclick="showPanel(\'dashboard\')"><i class="fas fa-home"></i> Dashboard</a><a onclick="showPanel(\'memberships\')"><i class="fas fa-users"></i> My Memberships</a><a><i class="fas fa-calendar"></i> My Calendar</a><a><i class="fas fa-life-ring"></i> Help Center</a></nav></div><div class="main"><div class="header-bar"><h1>My Societies Dashboard</h1><span class="badge">'+(s.length)+' joined</span></div><div id="dashboard"><div class="stats-row"><div class="stat-card"><strong>'+(s.length)+'</strong><span>Joined Societies</span></div><div class="stat-card"><strong>'+(s.reduce((a,s)=>a+(s.calendar||[]).length,0))+'</strong><span>Activities</span></div><div class="stat-card"><strong>'+(s.length?new Date(s[s.length-1].joinedAt).toLocaleDateString():'-')+'</strong><span>Latest Join</span></div></div>'+(s.length?'<div class="soc-grid">'+s.map(x=>'<div class="soc-card"><img src="'+x.hero+'" alt="'+x.title+'"><div class="body"><h4>'+x.title+'</h4><p>'+x.summary+'</p><div class="date">Joined: '+new Date(x.joinedAt).toLocaleDateString()+'</div></div></div>').join('')+'</div>':'<div class="empty"><i class="fas fa-users"></i><h3>No societies joined yet</h3><p>Go to Clubs section to find and join societies.</p></div>')+'</div><div id="memberships" style="display:none"><div class="card" style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px"><h3 style="color:#002d5a;margin-bottom:12px">Membership Overview</h3>'+(s.length?'<table style="width:100%;border-collapse:collapse"><thead><tr style="background:#002d5a;color:#fff"><th style="padding:10px">#</th><th style="padding:10px">Society</th><th style="padding:10px">Joined</th><th style="padding:10px">Status</th></tr></thead><tbody>'+s.map((x,i)=>'<tr style="border-bottom:1px solid #e2e8f0"><td style="padding:10px">'+(i+1)+'</td><td style="padding:10px"><strong>'+x.title+'</strong></td><td style="padding:10px">'+new Date(x.joinedAt).toLocaleDateString()+'</td><td style="padding:10px"><span style="background:#ecfdf5;color:#166534;padding:3px 10px;border-radius:999px;font-size:.8rem">Active</span></td></tr>').join('')+'</tbody></table>':'<p style="color:#64748b">No memberships yet.</p>')+'</div></div></div><script>function showPanel(p){document.getElementById(\'dashboard\').style.display=p===\'dashboard\'?\'block\':\'none\';document.getElementById(\'memberships\').style.display=p===\'memberships\'?\'block\':\'none\'}<\/script></body></html>');w.document.close()}
function openResearchWindow(c){const w=window.open('','_blank','width=1000,height=700');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>'+c.title+' - UFT Research</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:url(\''+c.img+'\') center/cover no-repeat;min-height:300px;position:relative}.hero:after{content:\'\';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,45,90,.15),rgba(15,23,42,.82))}.hero h1{position:absolute;bottom:18px;left:24px;color:#fff;z-index:1;margin:0}.shell{max-width:900px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.stat{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px dashed #e2e8f0}h2{color:#002d5a}</style></head><body><div class="hero"><h1>'+c.title+'</h1></div><div class="shell"><div class="card"><p style="line-height:1.8">'+c.copy+'</p></div><div class="grid2"><div class="card"><h2>Research Areas</h2><ul><li>Advanced research methodologies</li><li>Cross-disciplinary collaboration</li><li>Industry partnerships</li><li>Student researcher programs</li></ul></div><div class="card"><h2>Lab Metrics</h2><div class="stat"><strong>Researchers</strong><span>'+(c.researchers||'24')+'</span></div><div class="stat"><strong>Projects</strong><span>'+(c.projects||'12')+'</span></div><div class="stat"><strong>Partners</strong><span>'+(c.partners||'8')+'</span></div><div class="stat"><strong>Publications</strong><span>'+(c.publications||'34')+'</span></div></div></div></div></body></html>');w.document.close()}
function openIncomingWindow(){const w=window.open('','_blank','width=950,height=700');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Incoming Students - UFT</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:40px;text-align:center}.hero h1{margin:0}.shell{max-width:850px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin-top:10px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>Incoming Students</h1><p style="opacity:.9;margin-top:10px">Your journey to UFT starts here</p></div><div class="shell"><div class="card"><h2>Welcome to UFT</h2><p>Our international office supports students from over 80 countries with visa guidance, accommodation, orientation, and academic integration.</p></div><div class="grid2"><div class="card"><h3>Visa & Immigration</h3><p>Step-by-step visa application support and document checking.</p></div><div class="card"><h3>Accommodation</h3><p>Guaranteed on-campus housing for first-year international students.</p></div><div class="card"><h3>Language Support</h3><p>Free English courses, writing workshops, and conversation partners.</p></div><div class="card"><h3>Orientation</h3><p>Campus tours, bank setup, cultural events, and social activities.</p></div></div><a class="btn-p" href="application.html">Apply Now</a></div></body></html>');w.document.close()}
function openOutgoingWindow(){const w=window.open('','_blank','width=950,height=700');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Outgoing Students - UFT</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:40px;text-align:center}.hero h1{margin:0}.shell{max-width:850px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin-top:10px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}</style></head><body><div class="hero"><h1>Outgoing Students</h1><p style="opacity:.9;margin-top:10px">Study abroad and exchange programmes</p></div><div class="shell"><div class="card"><h2>Global Opportunities</h2><p>UFT students can study at 200+ partner universities in 40+ countries through Erasmus+ and exchange programmes.</p></div><div class="grid2"><div class="card"><h3>Erasmus+</h3><p>Study at European partner universities with funding support.</p></div><div class="card"><h3>Global Exchange</h3><p>Programmes in USA, Canada, Japan, Australia, and more.</p></div><div class="card"><h3>Application Process</h3><p>Apply through Global Office. Deadlines: March 1 and October 1.</p></div><div class="card"><h3>Funding</h3><p>Erasmus+ grants, travel bursaries, and merit scholarships.</p></div></div><a class="btn-p" href="application.html">Apply Now</a></div></body></html>');w.document.close()}
function openGlobalOfficeWindow(){const w=window.open('','_blank','width=900,height=650');if(!w)return;w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>UFT Global Office</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:40px;text-align:center}.hero h1{margin:0}.shell{max-width:650px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.info{display:grid;gap:10px}.info-item{padding:12px;background:#f8fafc;border-radius:10px;border:1px solid #e2e8f0}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin:4px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}</style></head><body><div class="hero"><h1>UFT Global Office</h1></div><div class="shell"><div class="card"><div class="info"><div class="info-item"><strong>Address</strong><br>E0-020, University of Fire Tech, Innovation Valley, CA</div><div class="info-item"><strong>Email</strong><br><a href="mailto:global@uft.edu" style="color:#ff5100;font-weight:700">global@uft.edu</a></div><div class="info-item"><strong>Phone</strong><br>+1 (800) 438-3863</div><div class="info-item"><strong>Hours</strong><br>Mon-Fri, 9:00-17:00</div></div></div><a class="btn-p" href="mailto:global@uft.edu"><i class="fas fa-envelope"></i> global@uft.edu</a></div></body></html>');w.document.close()}

// Core functions
function toggleCourse(i){const p=document.getElementById('acc-'+i);if(p)p.classList.toggle('active')}
function toggleAccordion(el){el.classList.toggle('active');const p=el.nextElementSibling;p.classList.toggle('show')}
function goEvent(key){window.location.href='event-detail.html?event='+encodeURIComponent(key)}
function moveMonth(n){calDate.setMonth(calDate.getMonth()+n);renderCalendar()}
function renderCalendar(){const g=document.getElementById('calGrid'),l=document.getElementById('monthLabel');if(!g||!l)return;const y=calDate.getFullYear(),m=calDate.getMonth(),first=new Date(y,m,1).getDay(),days=new Date(y,m+1,0).getDate(),today=new Date().toISOString().slice(0,10),eDates=eventsData.map(e=>e.date);l.textContent=calDate.toLocaleString('en',{month:'long',year:'numeric'});let h='<div class="n">Sun</div><div class="n">Mon</div><div class="n">Tue</div><div class="n">Wed</div><div class="n">Thu</div><div class="n">Fri</div><div class="n">Sat</div>';for(let i=0;i<first;i++)h+='<div class="d"></div>';for(let d=1;d<=days;d++){const ds=y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');const c=['d'];if(ds===today)c.push('today');if(eDates.includes(ds))c.push('event');h+='<div class="'+c.join(' ')+'">'+d+'</div>'}g.innerHTML=h}
function initCourseTable(type){const data=type==='undergrad'?ug:pg;const search=document.getElementById('courseSearch');const cat=document.getElementById('courseCat');const table=document.getElementById('courseTable');const detail=document.getElementById('courseDetail');if(!search||!cat||!table)return;function draw(){const q=(search.value||'').toLowerCase();const c=cat.value;const rows=data.filter(x=>{const txt=x.name+' '+x.code+' '+(x.college||x.school);return txt.toLowerCase().includes(q)&&(c==='all'||(x.category||x.stream)===c)});table.innerHTML=rows.map(x=>'<tr onclick="showCourse(\''+encodeURIComponent(x.name)+'\',\''+type+'\')" style="cursor:pointer;transition:.2s" onmouseover="this.style.background=\'#f1f5f9\'" onmouseout="this.style.background=\'\'"><td>'+x.name+'</td><td>'+x.code+'</td><td>'+(x.college||x.school)+'</td></tr>').join('')||'<tr><td colspan="3">No results</td></tr>';}search.addEventListener('input',draw);cat.addEventListener('change',draw);draw();if(detail)detail.classList.remove('active')}
function showCourse(encoded,type){const name=decodeURIComponent(encoded);const src=type==='undergrad'?ug:pg;const c=src.find(x=>x.name===name);if(!c)return;const d=document.getElementById('courseDetail');if(!d)return;d.innerHTML='<h3>'+c.name+'</h3><div class="meta" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px;margin-bottom:12px"><div class="meta-item" style="background:#f8fafc;border:1px solid var(--border);border-radius:10px;padding:10px"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Code</strong><span style="color:var(--secondary);font-weight:700">'+c.code+'</span></div><div class="meta-item"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Duration</strong><span style="color:var(--secondary);font-weight:700">'+c.duration+'</span></div><div class="meta-item"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Fees</strong><span style="color:var(--secondary);font-weight:700">'+c.fees+'</span></div><div class="meta-item"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Entry</strong><span style="color:var(--secondary);font-weight:700">'+c.entry+'</span></div></div><div class="cols"><div><h4>Key information</h4><ul style="padding-left:18px;color:var(--muted);line-height:1.7"><li><strong>About:</strong> '+c.about+'</li><li><strong>Apply:</strong> '+c.apply+'</li><li><strong>Funding:</strong> '+c.funding+'</li></ul><h4 style="margin-top:10px">Your future career</h4><ul style="padding-left:18px;color:var(--muted);line-height:1.7">'+c.career.map(x=>'<li>'+x+'</li>').join('')+'</ul></div><div><h4>What you will study</h4><ul style="padding-left:18px;color:var(--muted);line-height:1.7">'+c.study.map(x=>'<li>'+x+'</li>').join('')+'</ul><div style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap"><button class="btn btn-primary btn-sm" onclick="openCourseInWindow('+JSON.stringify(c).replace(/'/g,"\\'")+')">View Details <i class="fas fa-external-link-alt"></i></button><a class="btn btn-soft btn-sm" href="application.html?course='+encodeURIComponent(c.name)+'">Apply Now</a></div></div></div>';d.classList.add('active');d.scrollIntoView({behavior:'smooth',block:'start'})}
function initCatalog(){const all=[...ug.map(x=>({...x,org:x.college,group:'Undergraduate'})),...pg.map(x=>({...x,org:x.school,group:'Postgraduate'}))];const list=document.getElementById('catalogList');const detail=document.getElementById('catalogDetail');const search=document.getElementById('catalogSearch');if(!list||!search)return;function draw(){const q=(search.value||'').toLowerCase();const rows=all.filter(x=>(x.name+' '+x.code+' '+x.org).toLowerCase().includes(q));list.innerHTML=rows.map(x=>'<div class="card" style="cursor:pointer" onclick="showCatalog(\''+encodeURIComponent(x.name)+'\')"><h4>'+x.name+'</h4><p>'+x.code+' · '+x.group+' · '+x.org+'</p></div>').join('')||'<div class="card">No courses found.</div>';}window.showCatalog=function(encoded){const n=decodeURIComponent(encoded);const c=all.find(x=>x.name===n);if(!c)return;detail.innerHTML='<h3>'+c.name+'</h3><p>'+c.about+'</p><button class="btn btn-primary btn-sm" style="margin-top:10px" onclick="openCourseInWindow('+JSON.stringify(c).replace(/'/g,"\\'")+')">View Full Details <i class="fas fa-external-link-alt"></i></button>';detail.classList.add('active')};search.addEventListener('input',draw);draw()}
function openClubPopup(encoded,focusJoin){const club=JSON.parse(decodeURIComponent(encoded));const joinedCount=getSocieties().length;const profileHtml=`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>${club.title} - Profile</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{margin:0;font-family:Inter,sans-serif;background:linear-gradient(180deg,#fff,#f8fafc);color:#1e293b}.hero{min-height:34vh;background:url('${club.hero}') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,45,90,.12),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;font-size:clamp(2rem,4vw,3.6rem);margin:0;padding:28px}.shell{padding:24px;max-width:1120px;margin:0 auto}.card{background:#fff;border:1px solid #e2e8f0;border-radius:18px;padding:18px;box-shadow:0 10px 28px rgba(15,23,42,.06)}.grid2{display:grid;grid-template-columns:1.1fr .9fr;gap:14px;margin-top:14px}.gallery{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px}.img{border-radius:18px;overflow:hidden;min-height:240px;position:relative}.img img{width:100%;height:100%;object-fit:cover;display:block}.overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.72));color:#fff;display:flex;align-items:flex-end;padding:14px;font-weight:800}.pill{display:inline-block;padding:7px 12px;border-radius:999px;background:#fff7ed;color:#ff5100;border:1px solid #fed7aa;font-weight:800;font-size:.75rem}.action-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 16px;border-radius:12px;border:none;font:inherit;font-weight:800;cursor:pointer;margin:4px;text-decoration:none}.btn-primary{background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.btn-soft{background:#fff;border:1px solid #e2e8f0;color:#002d5a}.calendar-item{display:flex;justify-content:space-between;padding:12px 14px;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0;margin-bottom:8px}.calendar-item strong{color:#002d5a}.calendar-item span{color:#64748b;text-align:right}.section-title{color:#002d5a;font-weight:900;margin:0 0 8px}.tiny{font-size:.9rem;color:#64748b;line-height:1.7}@media(max-width:860px){.grid2,.gallery{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>${club.title}</h1></div><div class="shell"><div class="card"><span class="pill">Profile window</span><p style="margin-top:12px;line-height:1.8">${club.summary}</p><div class="action-row"><button class="btn btn-primary" onclick="document.querySelector('.grid2').scrollIntoView({behavior:'smooth'})"><i class="fas fa-user"></i> View Profile</button><button class="btn btn-soft" onclick="window.opener.openClubPopup('${encodeURIComponent(JSON.stringify(club))}',true)"><i class="fas fa-plus"></i> Open join window</button><button class="btn btn-soft" onclick="window.opener.openMySocietiesProfile()"><i class="fas fa-id-card"></i> My Societies</button></div></div><div class="grid2"><div class="card"><h3 class="section-title">Club profile</h3><p class="tiny">${club.profile}</p><div style="margin-top:12px"><strong>Focus</strong><p class="tiny">${club.focus}</p></div><div style="margin-top:12px"><strong>What members do</strong><p class="tiny">${club.activities}</p></div></div><div class="card"><h3 class="section-title">Calendar</h3><div class="calendar" style="display:grid;gap:10px">${(club.calendar||[]).map(i=>`<div class="calendar-item"><strong>${i.day}</strong><span>${i.event}</span></div>`).join('')}</div></div></div><div class="gallery"><div class="img"><img src="${club.hero}" alt="${club.title}"><div class="overlay">${club.detail}</div></div><div class="img"><img src="https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?w=1200" alt="Members"><div class="overlay">Members, events, and society life</div></div></div></div></body></html>`;const joinHtml=`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Join ${club.title}</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{margin:0;font-family:Inter,sans-serif;background:linear-gradient(180deg,#fff,#f8fafc);color:#1e293b}.hero{min-height:32vh;background:url('${club.hero}') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,81,0,.10),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;font-size:clamp(2rem,4vw,3.4rem);margin:0;padding:28px}.shell{padding:24px;max-width:1120px;margin:0 auto}.card{background:#fff;border:1px solid #e2e8f0;border-radius:18px;padding:18px;box-shadow:0 10px 28px rgba(15,23,42,.06)}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 16px;border-radius:12px;border:none;font:inherit;font-weight:800;cursor:pointer;margin-top:10px;text-decoration:none}.btn-primary{background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.btn-soft{background:#fff;border:1px solid #e2e8f0;color:#002d5a}.pill{display:inline-block;padding:7px 12px;border-radius:999px;background:#fef3c7;color:#92400e;border:1px solid #fde68a;font-weight:800;font-size:.75rem}.form{display:grid;gap:12px;margin-top:12px}.field{display:grid;gap:6px}.field input{padding:12px 14px;border:1px solid #e2e8f0;border-radius:10px;font:inherit}.note{color:#64748b;line-height:1.7}.calendar-item{display:flex;justify-content:space-between;padding:12px 14px;border-radius:14px;background:#f8fafc;border:1px solid #e2e8f0;margin-bottom:8px}.calendar-item strong{color:#002d5a}.calendar-item span{color:#64748b;text-align:right}.feature-list{display:grid;gap:10px}.feature{padding:12px 14px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0}@media(max-width:860px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>Join ${club.title}</h1></div><div class="shell"><div class="card"><span class="pill">Join window</span><p class="note" style="margin-top:10px">Complete your membership request here. This window is separate from the profile view so the join flow stays clear.</p><div class="form"><div class="field"><label>Email</label><input id="societyEmail" type="email" placeholder="student@uft.edu"></div><div class="field"><label>Motivation</label><input id="societyReason" type="text" placeholder="Why do you want to join?"></div><button class="btn btn-primary" onclick="window.opener.addSocietyMembership({title:'${club.title}',hero:'${club.hero}',summary:'${club.summary}',calendar:${JSON.stringify(club.calendar||[])}});this.textContent='Joined successfully';this.disabled=true;window.setTimeout(()=>window.opener.openMySocietiesProfile(),300)"><i class="fas fa-plus"></i> Join society</button><button class="btn btn-soft" onclick="window.close()"><i class="fas fa-xmark"></i> Close</button></div></div><div class="grid2"><div class="card"><h3 style="color:#002d5a;margin-bottom:8px">What joining gives you</h3><div class="feature-list"><div class="feature">Access to meetings, sessions, and events</div><div class="feature">Profile visibility inside My Societies</div><div class="feature">Calendar reminders and activity tracking</div></div></div><div class="card"><h3 style="color:#002d5a;margin-bottom:8px">Upcoming calendar</h3><div class="calendar-item"><strong>Weekly</strong><span>Open member drop-in</span></div><div class="calendar-item"><strong>Next event</strong><span>${(club.calendar&&club.calendar[0]&&club.calendar[0].event)||'Intro session'}</span></div><div class="calendar-item"><strong>Join status</strong><span>Ready to submit</span></div></div></div></div></body></html>`;const w=window.open('','_blank','width=1120,height=860');if(!w)return;w.document.write(focusJoin?joinHtml:profileHtml);w.document.close()}
function openCourseInWindow(courseInput){const course=typeof courseInput==='string'?JSON.parse(decodeURIComponent(courseInput)):courseInput;const w=window.open('','_blank','width=1100,height=800');if(!w)return;w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>${course.name} - UFT</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:40px;text-align:center}.hero h1{margin:0;font-size:2.2rem}.hero .code{color:#ff5100;font-weight:800;margin-top:6px}.shell{max-width:960px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.mg{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px}.mi{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px;text-align:center}.mi strong{display:block;color:#002d5a}.mi span{font-size:.78rem;color:#64748b;text-transform:uppercase;letter-spacing:1px}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff;margin-top:10px}h2{color:#002d5a}ul{line-height:1.9;color:#475569}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>${course.name}</h1><div class="code">${course.code||''}</div></div><div class="shell"><div class="card"><div class="mg"><div class="mi"><strong>${course.duration||'4 Years'}</strong><span>Duration</span></div><div class="mi"><strong>${course.fees||'$25K/yr'}</strong><span>Fees</span></div><div class="mi"><strong>${course.entry||'AAB'}</strong><span>Entry Requirements</span></div><div class="mi"><strong>${course.college||course.school||'UFT'}</strong><span>College</span></div></div><p style="margin-top:14px;line-height:1.8">${course.about||''}</p></div><div class="grid2"><div class="card"><h2>What You Will Study</h2><ul>${(course.study||['Core modules']).map(x=>'<li>'+x+'</li>').join('')}</ul></div><div class="card"><h2>Your Future Career</h2><ul>${(course.career||['Graduate roles']).map(x=>'<li>'+x+'</li>').join('')}</ul></div></div><div class="card"><h2>How to Apply</h2><p>${course.apply||'Apply through UFT online portal.'}</p><p><strong>Funding:</strong> ${course.funding||'Merit and access scholarships available.'}</p><a class="btn-p" href="application.html"><i class="fas fa-file-signature"></i> Apply Now</a></div></div></body></html>`);w.document.close()}
function sharePage(platform) {
  const url = encodeURIComponent(window.location.href);
  const title = encodeURIComponent(document.title);
  let shareUrl = '';
  if (platform === 'facebook') {
    shareUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + url;
  } else if (platform === 'linkedin') {
    shareUrl = 'https://www.linkedin.com/sharing/share-offsite/?url=' + url;
  } else if (platform === 'email') {
    shareUrl = 'mailto:?subject=' + title + '&body=Check this out: ' + url;
  }
  if (shareUrl) {
    window.open(shareUrl, '_blank', 'width=600,height=400');
  }
}
function openCourseDetails(encoded){openCourseInWindow(encoded)}
function openConsultationWindow(){const w=window.open('','_blank','width=980,height=760');if(!w)return;w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Course Consultation - UFT</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{background:linear-gradient(135deg,#002d5a,#0f172a);color:#fff;padding:42px 24px;text-align:center}.hero h1{margin:0;font-size:2.2rem}.shell{max-width:860px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px;box-shadow:0 10px 24px rgba(15,23,42,.05)}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.slot{padding:12px 14px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin-top:10px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.note{color:#64748b;line-height:1.7}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>Course Consultation</h1><p style="margin-top:10px;opacity:.9">Book a route-fitting session before you apply</p></div><div class="shell"><div class="card"><h2 style="color:#002d5a">What happens in consultation?</h2><p class="note">We compare your interests, entry grades, fees, and study goals, then recommend the route that fits you best. This is a separate advising flow, not the application form.</p></div><div class="grid2"><div class="card"><h3 style="color:#002d5a">Available slots</h3><div class="slot">Mon 10:00</div><div class="slot" style="margin-top:8px">Tue 14:30</div><div class="slot" style="margin-top:8px">Thu 11:00</div></div><div class="card"><h3 style="color:#002d5a">Bring with you</h3><div class="slot">Preferred course area</div><div class="slot" style="margin-top:8px">Academic transcript</div><div class="slot" style="margin-top:8px">Questions about fees and funding</div></div></div><div class="card"><h3 style="color:#002d5a">Book your consultation</h3><p class="note">Use this button to open the application page only after your advisory slot is confirmed.</p><a class="btn-p" href="application.html"><i class="fas fa-calendar-check"></i> Confirm consultation</a></div></div></body></html>`);w.document.close()}
function openVolunteerWindow(data){const w=window.open('','_blank','width=980,height=760');if(!w)return;w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>${data.title} - Volunteering</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"><style>body{font-family:Inter,sans-serif;background:#f8fafc;color:#1e293b;margin:0}.hero{min-height:280px;background:url('${data.img}') center/cover no-repeat;position:relative;display:flex;align-items:flex-end}.hero:after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,45,90,.12),rgba(15,23,42,.82))}.hero h1{position:relative;z-index:1;color:#fff;padding:24px;margin:0;font-size:2.2rem}.shell{max-width:860px;margin:0 auto;padding:24px}.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:14px}.btn-p{display:inline-flex;align-items:center;gap:8px;padding:11px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer;text-decoration:none;margin-top:10px;background:linear-gradient(135deg,#ff5100,#cc4100);color:#fff}.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}.feature{padding:12px 14px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0;margin-top:8px}.note{color:#64748b;line-height:1.7}@media(max-width:800px){.grid2{grid-template-columns:1fr}}</style></head><body><div class="hero"><h1>${data.title}</h1></div><div class="shell"><div class="card"><h2 style="color:#002d5a">${data.heading}</h2><p class="note">${data.text}</p></div><div class="grid2"><div class="card"><h3 style="color:#002d5a">Why it matters</h3><div class="feature">${data.one}</div><div class="feature">${data.two}</div><div class="feature">${data.three}</div></div><div class="card"><h3 style="color:#002d5a">Next steps</h3><p class="note">Join a project, meet the team, and sign up for the next volunteer day.</p><a class="btn-p" href="application.html"><i class="fas fa-heart"></i> Get involved</a></div></div></div></body></html>`);w.document.close()}
function sectionActivities(lang){const l=lang||'en';const rows=[{title:'Varsity Athletics',img:'https://images.unsplash.com/photo-1461896836934-bd45ba8fcf9b?w=1200',desc:'15 competitive teams across basketball, swimming, football, and track.'},{title:'Titan Gym and Recovery',img:'https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=1200',desc:'Strength training, recovery space, and performance support.'},{title:'Outdoor Adventure',img:'https://images.unsplash.com/photo-1518602164578-cd0074062767?w=1200',desc:'Kayaking, hiking, weekend trips, and challenge-based activities.'},{title:'Wellbeing in Motion',img:'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1200',desc:'Yoga, wellness walks, and stress-management sessions for students.'}];const plan=[['Monday','06:30','Track mechanics + sprint starts'],['Tuesday','17:00','Strength circuit + power work'],['Wednesday','18:30','Endurance interval blocks'],['Thursday','16:00','Mobility + recovery protocols'],['Friday','15:30','Game strategy and set pieces']];return `<section class="section"><div class="shell"><h2 class="title">Sports and Activities</h2><p class="sub">Athletics, wellness, and adventure experiences with clear student pathways.</p><div class="card" style="margin-bottom:14px"><h3>Sports Performance Hub</h3><p>Elite training, match analytics, recovery science, and student wellness in one connected experience.</p><div class="stats"><div class="stat"><strong data-count="42">0</strong><span>Competitive teams</span></div><div class="stat"><strong data-count="8">0</strong><span>Performance labs</span></div><div class="stat"><strong data-count="96">0</strong><span>Student participation</span></div><div class="stat"><strong data-count="24">0</strong><span>Gym access</span></div></div></div><div class="card" style="margin-bottom:14px;overflow:hidden;padding:0"><video controls playsinline muted autoplay loop poster="https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=1200" style="width:100%;height:520px;object-fit:cover;display:block"><source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">Your browser does not support the video tag.</video><div style="padding:16px 18px;background:#fff"><h4 style="margin:0 0 6px;color:var(--secondary)">Featured training reel</h4><p style="margin:0;color:var(--muted)">Watch our athletes in action. If playback is blocked, then you can refresh the page again to see if it works.</p></div></div><div class="gallery" style="grid-template-columns:1fr .9fr"><div class="img"><img src="${rows[0].img}" alt="${rows[0].title}"><div class="overlay">${rows[0].desc}</div></div><div class="img"><img src="${rows[2].img}" alt="${rows[2].title}"><div class="overlay">${rows[2].desc}</div></div></div><div class="table-wrap" style="margin-top:14px"><table><thead><tr><th>Day</th><th>Time</th><th>Session</th></tr></thead><tbody>${plan.map(p=>`<tr><td>${p[0]}</td><td>${p[1]}</td><td>${p[2]}</td></tr>`).join('')}</tbody></table></div><div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr));margin-top:14px">${rows.map(c=>`<details class="card"><summary style="cursor:pointer;font-weight:800;color:var(--secondary)">${c.title}</summary><p style="margin-top:10px">${c.desc}</p></details>`).join('')}</div></div></section>`}
function sectionVolunteering(lang){const l=lang||'en';const items=[{title:'Community Outreach',img:'https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=1200',heading:'Community outreach projects',text:'Support local schools, food drives, and digital inclusion work with a high-energy student team.',one:'Mentoring and tutoring that make a visible difference',two:'Short, practical projects with real community partners',three:'Leadership, empathy, and teamwork in action'},{title:'Global Service',img:'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1200',heading:'Global service opportunities',text:'Join international volunteer initiatives and learn how to contribute to sustainability, education, and health-focused campaigns.',one:'Global citizenship and intercultural awareness',two:'Partnerships with charities and NGOs',three:'Structured reflection and skills development'},{title:'Impact Media',img:'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1200',heading:'Impact-led media projects',text:'Create campaigns, film stories, and build visual content that helps social action projects reach more people.',one:'Photography, film, and social storytelling',two:'Portfolio-ready content creation',three:'Group work with community impact'},{title:'Volunteer Weekends',img:'https://images.unsplash.com/photo-1511578314322-379afb476865?w=1200',heading:'Volunteer weekends and events',text:'More time, more people, and more opportunities to make a difference across campus and beyond.',one:'Open days, clean-ups, and community events',two:'Easy sign-up routes and guidance',three:'A stronger volunteering network'}];return `<section class="section"><div class="shell"><h2 class="title">Volunteering and Community Engagement</h2><p class="sub">Service, outreach, and impact-led community projects.</p><div class="card" style="margin-bottom:14px"><h3 style="color:var(--secondary)">Why volunteering matters</h3><p>Volunteering here is not just a side activity. It is a way to build leadership, meet new people, and contribute to projects that have a visible impact on campus and in the wider community.</p></div><div class="media">${items.map(item=>`<div class="media-card" style="cursor:pointer" onclick='openVolunteerWindow(${JSON.stringify(item)})'><img src="${item.img}" alt="${item.title}"><div class="overlay">${item.title}</div></div>`).join('')}</div><div class="card" style="margin-top:16px"><h3 style="color:var(--secondary)">How to get involved</h3><p>Choose a project, open the image window to see the details, and use the volunteer window to move forward. Each tile opens its own page so the content is not squeezed into one small panel.</p></div></div></section>`}
function sectionInternational(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">About UFT Global</h2><p class="sub">University of Fire Tech (UFT) has been named among the top 500 universities globally.</p><div class="grid" style="grid-template-columns:1.2fr .8fr;margin-top:18px"><div class="card"><p>UFT is in the top 2% of universities worldwide. Located in Innovation Valley, California, our campus features state-of-the-art teaching and research facilities. We offer 70+ undergraduate and 100+ postgraduate programmes.</p><p style="margin-top:12px">International students are supported from pre-arrival to graduation through a joined-up global office, academic support, visa guidance, accommodation help, and social integration.</p><div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap"><button class="btn btn-primary" onclick="downloadPDF('about')"><i class="fas fa-download"></i> Download Brochure</button><button class="btn btn-soft" onclick="openIncomingWindow()"><i class="fas fa-plane-arrival"></i> Incoming students</button><button class="btn btn-soft" onclick="openOutgoingWindow()"><i class="fas fa-plane-departure"></i> Outgoing students</button></div></div><div class="card" style="overflow:hidden;padding:0"><img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1200" style="width:100%;height:320px;object-fit:cover"><div style="padding:18px"><h4 style="color:var(--secondary);margin:0 0 6px">Award-winning campus</h4><p style="margin:0;color:var(--muted)">Voted #1 for student experience</p></div></div></div><div class="stats" style="margin-top:18px"><div class="stat"><strong>70+</strong><span>Undergraduate programmes</span></div><div class="stat"><strong>100+</strong><span>Postgraduate programmes</span></div><div class="stat"><strong>#1</strong><span>Student Innovation</span></div><div class="stat"><strong>Top 2%</strong><span>Universities globally</span></div></div><div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;margin-top:18px"><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="openIncomingWindow()"><img src="https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h3 style="color:var(--secondary);margin:0 0 8px">Incoming Students</h3><p>Everything you need to know if you are studying outside Ireland and coming to UFT.</p><button class="btn btn-primary btn-sm" onclick="event.stopPropagation();openIncomingWindow()">Open window</button></div></div><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="openOutgoingWindow()"><img src="https://images.unsplash.com/photo-1522071823991-b99c223a709e?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h3 style="color:var(--secondary);margin:0 0 8px">Outgoing Students</h3><p>Study abroad, Erasmus+, exchange, and global mobility support for UFT students.</p><button class="btn btn-primary btn-sm" onclick="event.stopPropagation();openOutgoingWindow()">Open window</button></div></div><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="openGlobalOfficeWindow()"><img src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=1200" style="width:100%;height:220px;object-fit:cover"><div style="padding:18px"><h3 style="color:var(--secondary);margin:0 0 8px">Global Office</h3><p>Visa, accommodation, orientation, and international student support all in one place.</p><button class="btn btn-primary btn-sm" onclick="event.stopPropagation();openGlobalOfficeWindow()">Open window</button></div></div></div><div class="callout"><div><h3>UFT Global Office</h3><p>E0-020, University of Fire Tech, Innovation Valley, CA | Get in Touch</p></div><div style="display:flex;gap:10px;flex-wrap:wrap"><button class="btn btn-primary" onclick="openGlobalOfficeWindow()"><i class="fas fa-envelope"></i> global@uft.edu</button><button class="btn btn-soft" onclick="downloadPDF('about')" style="background:#fff;color:#0f172a;border-color:#fff"><i class="fas fa-download"></i> Brochure</button></div></div></div></section>`}
function sectionHelp(lang){const l=lang||'en';return `<section class="section"><div class="shell"><h2 class="title">Help & Support</h2><p class="sub">If you have a question and you are not sure where to start, these support routes will point you in the right direction.</p><div class="card" style="margin-bottom:14px"><div class="grid" style="grid-template-columns:1.1fr .9fr;gap:18px"><div><h3 style="color:var(--secondary)">If you have a question and you are not sure where to start...</h3><p>...why not check if the information you are looking for is included on our helpful Ask UFT page?</p><p style="margin-top:10px">It has frequently asked questions on topics like IT, semester dates, and how to join a sports club. Search by keyword or look through our Hot Topics for questions that are particularly relevant right now.</p></div><div><h3 style="color:var(--secondary)">Visit us in person</h3><p>Student Central, Innovation Hub building, Ground Floor. If you cannot see us, ring the bell and we will guide you to the right team.</p></div></div></div><div class="card" style="margin-bottom:14px"><h3>Office Hours</h3><table><thead><tr><th>Day</th><th>Morning</th><th>Afternoon</th></tr></thead><tbody><tr><td>Mon-Thu</td><td>9:00-13:00</td><td>14:00-17:00</td></tr><tr><td>Friday</td><td>9:00-13:00</td><td>14:00-17:00</td></tr></tbody></table></div><div class="grid" style="grid-template-columns:1fr 1fr;gap:14px"><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="window.open('mailto:studentservices@uft.edu')"><div style="background:linear-gradient(135deg,var(--secondary),#001d3a);padding:30px;text-align:center;color:#fff"><h4 style="color:#fff">Current Student Queries</h4><p>studentservices@uft.edu</p></div></div><div class="card" style="overflow:hidden;padding:0;cursor:pointer" onclick="window.open('mailto:admissions@uft.edu')"><div style="background:linear-gradient(135deg,var(--primary),var(--primary-dark));padding:30px;text-align:center;color:#fff"><h4 style="color:#fff">Prospective Student Queries</h4><p>admissions@uft.edu</p></div></div></div><div class="card" style="margin-top:14px"><h3 style="color:var(--secondary)">Share</h3><div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:10px"><a class="btn btn-soft" href="#" onclick="sharePage('facebook');return false;"><i class="fab fa-facebook"></i> Facebook</a><a class="btn btn-soft" href="#" onclick="sharePage('linkedin');return false;"><i class="fab fa-linkedin"></i> Linkedin</a><a class="btn btn-soft" href="#" onclick="sharePage('email');return false;"><i class="fas fa-envelope"></i> Email</a></div></div></div></section>`}
function sectionFAQ(lang){const l=lang||'en';return `<section class="section" id="faqSection"><div class="shell"><h2 class="title">Frequently Asked Questions</h2><p class="sub">Common questions about studying at UFT, including fees, accommodation, applications, and support.</p><div class="accordion"><div><button class="acc-btn" onclick="toggleAccordion(this)">What are the tuition fees? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Undergraduate: $22,000-$25,400/yr. Postgraduate: $30,500-$45,000 total. PhD: fully funded with stipend. 80% of students receive financial aid.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">What accommodation options are available? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Guaranteed on-campus for first year. Options: Fire Hall, Tech Apartments, International House, Graduate Village. All include high-speed internet and 24/7 security.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">How do I apply? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Apply through UFT online portal. Deadlines: Early Decision Nov 15, Regular Jan 15, International Feb 1.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Can I study abroad? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Yes! UFT has 200+ partner universities in 40+ countries. Erasmus+ and exchange programmes available.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">What support is available for international students? <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>International students can access visa guidance, arrival support, accommodation help, language workshops, and Student Central support.</p></div></div><div><button class="acc-btn" onclick="toggleAccordion(this)">Contact UFT <i class="fas fa-chevron-down"></i></button><div class="acc-panel"><p>Email: studentservices@uft.edu | Phone: +1 (800) 438-3863 | Innovation Hub, Ground Floor</p></div></div></div></div></section>`}
function sectionCatalog(lang){const l=lang||'en';const all=[...ug.map(c=>({...c,group:'Undergraduate',org:c.college})),...pg.map(c=>({...c,group:'Postgraduate',org:c.school}))];return `<section class="section"><div class="shell"><h2 class="title">Course catalog and guidance</h2><p class="sub">Includes consultation, meetings, route fit guidance, and full profile information.</p><div class="grid" style="grid-template-columns:1fr 1fr"><div class="card"><h3>Consultation and meeting</h3><p>Book advising sessions to compare routes and entry requirements.</p><a class="btn btn-primary" href="javascript:;" onclick="openConsultationWindow()"><i class="fas fa-calendar-check"></i> Book consultation</a></div><div class="card"><h3>Which course is right for you?</h3><p>Filter by school, course code, and study goals, then open full details.</p></div></div><div class="filters"><input id="catalogSearch" placeholder="Search by course name, code, or school"></div><div id="catalogList" class="grid"></div><div id="catalogDetail" class="card detail"></div></div></section>`}
function showCourse(encoded,type){const name=decodeURIComponent(encoded);const src=type==='undergrad'?ug:pg;const c=src.find(x=>x.name===name);if(!c)return;const d=document.getElementById('courseDetail');if(!d)return;d.innerHTML=`<h3>${c.name}</h3><div class="meta" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px;margin-bottom:12px"><div class="meta-item" style="background:#f8fafc;border:1px solid var(--border);border-radius:10px;padding:10px"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Code</strong><span style="color:var(--secondary);font-weight:700">${c.code}</span></div><div class="meta-item" style="background:#f8fafc;border:1px solid var(--border);border-radius:10px;padding:10px"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Duration</strong><span style="color:var(--secondary);font-weight:700">${c.duration}</span></div><div class="meta-item" style="background:#f8fafc;border:1px solid var(--border);border-radius:10px;padding:10px"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Fees</strong><span style="color:var(--secondary);font-weight:700">${c.fees}</span></div><div class="meta-item" style="background:#f8fafc;border:1px solid var(--border);border-radius:10px;padding:10px"><strong style="display:block;font-size:.74rem;color:var(--muted);text-transform:uppercase">Entry</strong><span style="color:var(--secondary);font-weight:700">${c.entry}</span></div></div><div class="cols"><div><h4>Key information</h4><ul style="padding-left:18px;color:var(--muted);line-height:1.7"><li><strong>About:</strong> ${c.about}</li><li><strong>Apply:</strong> ${c.apply}</li><li><strong>Funding:</strong> ${c.funding}</li></ul><h4 style="margin-top:10px">Your future career</h4><ul style="padding-left:18px;color:var(--muted);line-height:1.7">${c.career.map(x=>`<li>${x}</li>`).join('')}</ul></div><div><h4>What you will study</h4><ul style="padding-left:18px;color:var(--muted);line-height:1.7">${c.study.map(x=>`<li>${x}</li>`).join('')}</ul><div style="margin-top:12px;display:flex;gap:10px;flex-wrap:wrap"><button class="btn btn-primary btn-sm" onclick="openCourseDetails('${encodeURIComponent(JSON.stringify(c))}')">View Details <i class="fas fa-external-link-alt"></i></button><a class="btn btn-soft btn-sm" href="application.html?course=${encodeURIComponent(c.name)}">Apply Now</a></div></div></div>`;d.classList.add('active');d.scrollIntoView({behavior:'smooth',block:'start'})}
function initCatalog(){const all=[...ug.map(x=>({...x,org:x.college,group:'Undergraduate'})),...pg.map(x=>({...x,org:x.school,group:'Postgraduate'}))];const list=document.getElementById('catalogList');const detail=document.getElementById('catalogDetail');const search=document.getElementById('catalogSearch');if(!list||!search)return;function draw(){const q=(search.value||'').toLowerCase();const rows=all.filter(x=>(x.name+' '+x.code+' '+x.org).toLowerCase().includes(q));list.innerHTML=rows.map(x=>`<div class="card" style="cursor:pointer" onclick="showCatalog('${encodeURIComponent(x.name)}')"><h4>${x.name}</h4><p>${x.code} · ${x.group} · ${x.org}</p></div>`).join('')||'<div class="card">No courses found.</div>';}window.showCatalog=function(encoded){const n=decodeURIComponent(encoded);const c=all.find(x=>x.name===n);if(!c)return;detail.innerHTML=`<h3>${c.name}</h3><p>${c.about}</p><button class="btn btn-primary btn-sm" style="margin-top:10px" onclick="openCourseDetails('${encodeURIComponent(JSON.stringify(c))}')">View Full Details <i class="fas fa-external-link-alt"></i></button>`;detail.classList.add('active')};search.addEventListener('input',draw);draw()}
function animateCounters(){document.querySelectorAll('[data-count]').forEach(el=>{if(el.dataset.done)return;const end=Number(el.getAttribute('data-count')||0);el.dataset.done='1';let cur=0;const si=setInterval(()=>{cur+=Math.ceil(end/30);if(cur>=end){cur=end;clearInterval(si)}el.textContent=String(cur)},20)})}
function runPageAnimations(){const els=[...document.querySelectorAll('.card,.stat,.btn,.ad,.person,.media-card,.callout,.title,.sub')].filter(el=>getComputedStyle(el).display!=='none');els.forEach((el,i)=>{el.classList.remove('motion-in');el.classList.add('motion-ready');el.style.animationDelay=Math.min(i*35,420)+'ms';requestAnimationFrame(()=>el.classList.add('motion-in'))})}
function applyLanguage(lang){localStorage.setItem('uftLanguage',lang);document.documentElement.lang=lang;const p=languagePacks[lang]||languagePacks.en;const h=document.getElementById('backHomeLabel');const a=document.getElementById('applyLabel');if(h)h.textContent=p.backHome;if(a)a.textContent=p.apply;render()}
function goSection(s){window.location.href='section-view.html?section='+encodeURIComponent(s)}
function render(){const lang=getLang();const m=getMeta(sectionSlug);let html=renderHero(m);if(sectionSlug==='undergrad'||sectionSlug==='postgrad'){html+=sectionCourses(sectionSlug,lang)}else if(sectionSlug==='digital'){html+=sectionDigital()}else if(sectionSlug==='events'){html+=sectionEvents(lang)}else if(sectionSlug==='clubs'){html+=sectionClubs(lang)}else if(sectionSlug==='activities'){html+=sectionActivities(lang)}else if(sectionSlug==='research'){html+=sectionResearch(lang)}else if(sectionSlug==='campusmap'){html+=sectionMap(lang)}else if(sectionSlug==='libraries'){html+=sectionLibraries(lang)}else if(sectionSlug==='volunteering'){html+=sectionVolunteering(lang)}else if(sectionSlug==='catalog'){html+=sectionCatalog(lang)}else if(sectionSlug==='international'){html+=sectionInternational(lang)}else if(sectionSlug==='help'){html+=sectionHelp(lang)}else if(sectionSlug==='faq'){html+=sectionFAQ(lang)}else if(sectionSlug==='business'||sectionSlug==='law'){html+=`<section class="section"><div class="shell"><h2 class="title">Integrated into undergraduate and postgraduate tabs</h2><p class="sub">Business and Law are now presented inside undergraduate and postgraduate listings, not as separate isolated routes.</p><div class="grid" style="grid-template-columns:1fr 1fr"><div class="card"><h3>Undergraduate listing</h3><p>Includes business and law tracks with complete profile details.</p><a class="btn btn-primary" href="section-view.html?section=undergrad">Open undergraduate</a></div><div class="card"><h3>Postgraduate listing</h3><p>Includes MBA and LLM-style pathways in postgraduate tab.</p><a class="btn btn-primary" href="section-view.html?section=postgrad">Open postgraduate</a></div></div></div></section>`}else{html+=sectionGeneric(m)}
html+=`<section class="section"><div class="shell"><div class="callout"><div><h3>Continue with your next action</h3><p>Use brochure, application, and payment from this section page.</p></div><div style="display:flex;gap:10px;flex-wrap:wrap"><a class="btn btn-primary" href="application.html"><i class="fas fa-file-signature"></i> Apply now</a><a class="btn btn-soft" href="${m.brochure}" target="_blank" rel="noopener"><i class="fas fa-file-pdf"></i> Brochure PDF</a><a class="btn btn-soft" href="${m.payment}"><i class="fas fa-credit-card"></i> Payment portal</a></div></div></div></section>`;document.getElementById('sectionRoot').innerHTML=html;if(sectionSlug==='undergrad'||sectionSlug==='postgrad')initCourseTable(sectionSlug);if(sectionSlug==='catalog')initCatalog();if(sectionSlug==='events')renderCalendar();runPageAnimations();animateCounters()}
const langSelect=document.getElementById('languageSelect');langSelect.value=localStorage.getItem('uftLanguage')||'en';langSelect.addEventListener('change',e=>applyLanguage(e.target.value));document.getElementById('siteVersion').textContent=siteVersion;render();
</script>
</body>
</html>